---
import Sidebar from "../components/Sidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";
import "../styles/global.css";
import { BASE } from "../lib/base";

const {
  title,
  course,
  week,
  headings = [],
  prev,
  next,
  currentSlug,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      (function () {
        const saved = localStorage.getItem("theme");
        if (saved === "light") {
          document.documentElement.setAttribute("data-theme", "light");
        } else if (
          !saved &&
          window.matchMedia("(prefers-color-scheme: light)").matches
        ) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
    <title>{title} - DE Specialization Notes</title>
    <meta
      name="description"
      content={`Notes for ${title} from the Data Engineering Specialization`}
    />
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
  </head>
  <body>
    <!-- Mobile top bar -->
    <div class="mobile-topbar">
      <button id="sidebar-open" aria-label="Open navigation">
        <svg
          width="20"
          height="20"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      <span class="mobile-title">{title}</span>
    </div>

    <!-- Overlay for mobile sidebar -->
    <div id="sidebar-overlay" class="sidebar-overlay"></div>

    <div class="layout">
      <Sidebar currentSlug={currentSlug} />

      <main class="main-content">
        <article class="article">
          <!-- Breadcrumb -->
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <span class="breadcrumb-course">{course}</span>
            <span class="breadcrumb-sep">›</span>
            <span class="breadcrumb-week">{week}</span>
          </nav>

          <h1 class="page-title" data-pagefind-ignore>{title}</h1>

          <div class="prose" id="prose-content" data-pagefind-body>
            <slot />
          </div>

          <!-- Prev/Next navigation -->
          <nav class="page-nav" aria-label="Previous and next">
            <div class="page-nav-prev">
              {
                prev && (
                  <a href={`${BASE}/notes/${prev.slug}/`} class="page-nav-link">
                    <span class="page-nav-label">← Previous</span>
                    <span class="page-nav-title">{prev.title}</span>
                  </a>
                )
              }
            </div>
            <div class="page-nav-next">
              {
                next && (
                  <a href={`${BASE}/notes/${next.slug}/`} class="page-nav-link">
                    <span class="page-nav-label">Next →</span>
                    <span class="page-nav-title">{next.title}</span>
                  </a>
                )
              }
            </div>
          </nav>
        </article>
      </main>

      <!-- Right TOC (wide screens only) -->
      <aside class="toc-aside">
        <TableOfContents headings={headings} />
      </aside>
    </div>

    <!-- Mobile diagram lightbox -->
    <dialog id="diagram-lightbox" class="diagram-lightbox">
      <button class="diagram-lightbox-close" aria-label="Close">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <img id="diagram-lb-light" class="diagram-lb-img diagram-light" alt="" />
      <img id="diagram-lb-dark" class="diagram-lb-img diagram-dark" alt="" />
      <div id="diagram-lb-svg" class="diagram-lb-svg"></div>
    </dialog>

    <script>
      const openBtn = document.getElementById("sidebar-open");
      const closeBtn = document.getElementById("sidebar-close");
      const sidebar = document.getElementById("sidebar");
      const overlay = document.getElementById("sidebar-overlay");

      function openSidebar() {
        sidebar?.classList.add("open");
        overlay?.classList.add("visible");
        document.body.style.overflow = "hidden";
      }
      function closeSidebar() {
        sidebar?.classList.remove("open");
        overlay?.classList.remove("visible");
        document.body.style.overflow = "";
      }

      openBtn?.addEventListener("click", openSidebar);
      closeBtn?.addEventListener("click", closeSidebar);
      overlay?.addEventListener("click", closeSidebar);
    </script>

    <script>
      function wrapSectionsInCards() {
        const prose = document.getElementById("prose-content");
        if (!prose) return;

        const children = Array.from(prose.children);
        if (children.length === 0) return;

        const hasH2 = children.some(function (c) {
          return c.tagName === "H2";
        });
        if (!hasH2) return;

        const fragments = [];
        let current = [];

        for (let i = 0; i < children.length; i++) {
          const child = children[i];
          if (child.tagName === "H2" && current.length > 0) {
            fragments.push(current);
            current = [];
          }
          current.push(child);
        }
        if (current.length > 0) fragments.push(current);

        while (prose.firstChild) prose.removeChild(prose.firstChild);

        for (let f = 0; f < fragments.length; f++) {
          const group = fragments[f];
          if (group[0].tagName !== "H2") {
            for (let j = 0; j < group.length; j++) prose.appendChild(group[j]);
            continue;
          }
          const card = document.createElement("div");
          card.className = "content-card";
          for (let k = 0; k < group.length; k++) card.appendChild(group[k]);
          prose.appendChild(card);
        }
      }

      wrapSectionsInCards();
    </script>

    <script>
      (function () {
        const lightbox = document.getElementById(
          "diagram-lightbox",
        ) as HTMLDialogElement;
        const lbImgLight = document.getElementById(
          "diagram-lb-light",
        ) as HTMLImageElement;
        const lbImgDark = document.getElementById(
          "diagram-lb-dark",
        ) as HTMLImageElement;
        const lbSvgContainer = document.getElementById(
          "diagram-lb-svg",
        ) as HTMLDivElement;
        const lbClose = lightbox.querySelector(".diagram-lightbox-close")!;

        function clearSvgContainer() {
          while (lbSvgContainer.firstChild)
            lbSvgContainer.removeChild(lbSvgContainer.firstChild);
        }

        function openImgLightbox(
          lightSrc: string,
          darkSrc: string,
          alt: string,
        ) {
          lbImgLight.src = lightSrc;
          lbImgLight.alt = alt;
          lbImgDark.src = darkSrc;
          lbImgDark.alt = alt;
          lbImgLight.style.display = "";
          lbImgDark.style.display = "";
          lbSvgContainer.classList.remove("is-active");
          clearSvgContainer();
          lightbox.showModal();
        }

        function openSvgLightbox(svg: SVGElement) {
          const clone = svg.cloneNode(true) as SVGElement;
          clone.style.maxWidth = "85vw";
          clone.style.maxHeight = "80vh";
          clone.style.width = "100%";
          clone.style.height = "auto";
          lbImgLight.style.display = "none";
          lbImgDark.style.display = "none";
          lbSvgContainer.classList.add("is-active");
          clearSvgContainer();
          lbSvgContainer.appendChild(clone);
          lightbox.showModal();
        }

        // Use event delegation so dynamically rendered Mermaid diagrams work
        const prose = document.getElementById("prose-content");
        if (prose) {
          prose.addEventListener("click", function (e) {
            const target = e.target as HTMLElement;

            // Static diagram images (light/dark pairs)
            const img = target.closest("img.diagram") as HTMLImageElement;
            if (img) {
              const isDark = img.classList.contains("diagram-dark");
              const sibling = isDark
                ? img.nextElementSibling
                : img.previousElementSibling;

              let lightSrc: string;
              let darkSrc: string;
              if (isDark) {
                darkSrc = img.src;
                lightSrc =
                  sibling instanceof HTMLImageElement &&
                  sibling.classList.contains("diagram-light")
                    ? sibling.src
                    : img.src;
              } else {
                lightSrc = img.src;
                darkSrc =
                  sibling instanceof HTMLImageElement &&
                  sibling.classList.contains("diagram-dark")
                    ? sibling.src
                    : img.src;
              }
              openImgLightbox(lightSrc, darkSrc, img.alt);
              return;
            }

            // Mermaid diagrams (SVG inside .mermaid-diagram)
            const mermaidEl = target.closest(".mermaid-diagram");
            if (mermaidEl) {
              const svg = mermaidEl.querySelector("svg");
              if (svg) openSvgLightbox(svg);
            }
          });
        }

        // Close handlers
        lbClose.addEventListener("click", function () {
          lightbox.close();
        });
        lightbox.addEventListener("click", function (e) {
          if (e.target === lightbox) lightbox.close();
        });
      })();
    </script>
  </body>
</html>

<style>
  .layout {
    display: flex;
    min-height: 100vh;
  }

  .main-content {
    flex: 1;
    min-width: 0;
    overflow-x: hidden;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 860px;
  }

  .article {
    width: 100%;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1rem;
    font-size: 0.78rem;
    color: var(--fg-soft);
  }

  .breadcrumb-course {
    font-family: var(--font-serif);
  }
  .breadcrumb-week {
    font-family: var(--font-sans);
  }
  .breadcrumb-sep {
    color: var(--line-strong);
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }

  .toc-aside {
    padding: 2rem 1rem 2rem 0;
    flex-shrink: 0;
  }

  /* Page nav */
  .page-nav {
    display: flex;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .page-nav-prev {
    flex: none;
  }
  .page-nav-next {
    flex: none;
    text-align: right;
    margin-left: auto;
  }

  .page-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-decoration: none;
    padding: 0.75rem;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--bg-card);
    width: fit-content;
    transition:
      border-color 0.15s,
      background 0.15s,
      transform 0.15s,
      box-shadow 0.15s;
  }

  .page-nav-link:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: 0 4px 12px var(--shadow-soft);
  }

  .page-nav-label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--fg-soft);
    font-weight: 500;
  }

  .page-nav-title {
    font-family: var(--font-serif);
    font-size: 0.875rem;
    color: var(--fg);
    font-weight: 500;
  }

  .page-nav-next .page-nav-label {
    justify-content: flex-end;
    display: flex;
  }

  /* Mobile topbar */
  .mobile-topbar {
    display: none;
    position: sticky;
    top: 0;
    z-index: 40;
    background-color: var(--bg);
    border-bottom: 1px solid var(--line);
    padding: 0.75rem 1rem;
    align-items: center;
    gap: 0.75rem;
  }

  .mobile-topbar button {
    background: none;
    border: none;
    color: var(--fg-muted);
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
  }

  .mobile-title {
    font-family: var(--font-serif);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 49;
  }

  .sidebar-overlay.visible {
    display: block;
  }

  @media (max-width: 1200px) {
    .toc-aside {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .mobile-topbar {
      display: flex;
    }
    .main-content {
      padding: 1.25rem 1rem;
    }
    .page-title {
      font-size: 1.4rem;
    }
    .page-nav-prev,
    .page-nav-next {
      flex: 1;
      min-width: 0;
    }
    .page-nav-link {
      width: auto;
    }
  }

  /* Mobile diagram tap hint */
  @media (max-width: 768px) {
    :global(.prose img.diagram) {
      cursor: pointer;
    }
    :global(.mermaid-diagram) {
      cursor: pointer;
    }
  }

  /* Diagram lightbox */
  .diagram-lightbox {
    border: none;
    background: var(--bg-card);
    max-width: 90vw;
    max-height: 90vh;
    padding: 1.5rem;
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3);
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    margin: 0;
  }
  .diagram-lightbox::backdrop {
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .diagram-lightbox .diagram-lb-img {
    max-width: 85vw;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 10px;
    display: block;
  }
  .diagram-lightbox .diagram-lb-svg {
    display: none;
  }
  .diagram-lightbox .diagram-lb-svg.is-active {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .diagram-lightbox .diagram-lightbox-close {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: var(--bg-card);
    color: var(--fg-soft);
    border: 1px solid var(--line);
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
    z-index: 10;
  }
  .diagram-lightbox .diagram-lightbox-close:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .diagram-lightbox .diagram-lightbox-close:focus {
    outline: none;
  }
  .diagram-lightbox .diagram-dark {
    display: none;
  }
  :global(:root:not([data-theme="light"])) .diagram-lightbox .diagram-dark {
    display: block;
  }
  :global(:root:not([data-theme="light"])) .diagram-lightbox .diagram-light {
    display: none;
  }
</style>
