---
const { id = "search" } = Astro.props;
---

<div class="search-inline" id={id}>
  <div class="search-input-wrap">
    <svg
      class="search-icon"
      width="15"
      height="15"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <circle cx="11" cy="11" r="8"></circle><line
        x1="21"
        y1="21"
        x2="16.65"
        y2="16.65"></line>
    </svg>
    <input
      type="text"
      class="search-input"
      placeholder="Search..."
      autocomplete="off"
    />
    <kbd class="search-kbd"></kbd>
    <button class="search-clear" type="button" aria-label="Clear search" hidden
      >✕</button
    >
  </div>
  <div class="search-dropdown" hidden>
    <p class="search-message" hidden></p>
    <div class="search-results"></div>
  </div>
</div>

<style>
  .search-inline {
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    position: relative;
  }

  .search-input-wrap {
    position: relative;
  }

  /* Topbar variant: wider input */
  :global(.home-topbar-actions) .search-inline {
    max-width: 400px;
    width: 400px;
  }

  @media (max-width: 640px) {
    :global(.home-topbar-actions) .search-inline {
      width: 100%;
      max-width: 100%;
      flex: 1;
    }
  }

  .search-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 14px;
    box-shadow:
      0 8px 32px var(--shadow-soft),
      0 2px 8px rgba(0, 0, 0, 0.1);
    max-height: 420px;
    overflow-y: auto;
    padding: 0.5rem;
  }

  .search-dropdown::-webkit-scrollbar {
    width: 6px;
  }
  .search-dropdown::-webkit-scrollbar-track {
    background: transparent;
  }
  .search-dropdown::-webkit-scrollbar-thumb {
    background: var(--line);
    border-radius: 3px;
  }
</style>

<script>
  import { initPagefind, search } from "../lib/search-engine";
  import {
    renderResults,
    setupKeyboardNav,
    isMac,
    createDevFallback,
  } from "../lib/search-ui";

  const container = document.querySelector(".search-inline") as HTMLElement;
  const input = container?.querySelector<HTMLInputElement>(".search-input");
  const kbd = container?.querySelector<HTMLElement>(".search-kbd");
  const clearBtn = container?.querySelector<HTMLButtonElement>(".search-clear");
  const dropdown = container?.querySelector<HTMLElement>(".search-dropdown");
  const resultsEl = container?.querySelector<HTMLElement>(".search-results");
  const messageEl = container?.querySelector<HTMLElement>(".search-message");

  if (kbd) {
    kbd.textContent = isMac() ? "⌘K" : "Ctrl K";
  }

  async function init() {
    const ok = await initPagefind();
    if (!ok) {
      createDevFallback(container);
      // Hide the real search UI in dev mode
      const wrap = container.querySelector<HTMLElement>(".search-input-wrap");
      if (wrap) wrap.hidden = true;
      return;
    }

    if (input && resultsEl && dropdown) {
      input.addEventListener("input", async () => {
        const query = input.value;
        // Toggle badge vs clear button
        if (kbd) kbd.hidden = !!query;
        if (clearBtn) clearBtn.hidden = !query;

        // Empty input: return to initial state
        if (!query.trim()) {
          dropdown.hidden = true;
          while (resultsEl.firstChild)
            resultsEl.removeChild(resultsEl.firstChild);
          if (messageEl) messageEl.hidden = true;
          return;
        }

        // Any non-empty input: search and show results
        const results = await search(query);
        renderResults(resultsEl, results, messageEl || undefined);
        dropdown.hidden = results.length === 0;
      });

      // Clear button
      if (clearBtn) {
        clearBtn.addEventListener("click", () => {
          input.value = "";
          if (kbd) kbd.hidden = false;
          clearBtn.hidden = true;
          dropdown.hidden = true;
          // Clear results container using safe DOM method
          while (resultsEl.firstChild)
            resultsEl.removeChild(resultsEl.firstChild);
          input.focus();
        });
      }

      // Close dropdown on click outside
      document.addEventListener("click", (e) => {
        if (!container.contains(e.target as Node)) {
          dropdown.hidden = true;
        }
      });

      // Re-show dropdown on focus if there are results
      input.addEventListener("focus", () => {
        if (input.value.trim() && resultsEl.children.length > 0) {
          dropdown.hidden = false;
        }
      });

      setupKeyboardNav(input, resultsEl, () => {
        dropdown.hidden = true;
        input.blur();
      });
    }
  }

  // Cmd/Ctrl+K to focus search
  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      input?.focus();
    }
  });

  init();
</script>
