---
---

<!-- Trigger button in sidebar -->
<button class="search-trigger" type="button" aria-label="Search">
  <svg class="search-trigger-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
  <span class="search-trigger-text">Search...</span>
  <kbd class="search-trigger-kbd"></kbd>
</button>

<!-- Native dialog modal -->
<dialog class="search-dialog" id="search-dialog">
  <div class="search-dialog-header">
    <svg class="search-dialog-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input type="text" class="search-input search-dialog-input" placeholder="Search..." autocomplete="off" />
    <kbd class="search-dialog-kbd"></kbd>
    <button class="search-dialog-close" type="button" aria-label="Clear search" hidden>✕</button>
  </div>
  <div class="search-dialog-body" hidden>
    <p class="search-message" hidden></p>
    <div class="search-results"></div>
  </div>
</dialog>

<style>
  /* ── Trigger button ── */
  .search-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.5rem 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--fg-soft);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .search-trigger:hover {
    border-color: var(--accent);
    color: var(--fg-muted);
  }

  .search-trigger-icon {
    flex-shrink: 0;
  }

  .search-trigger-text {
    flex: 1;
    text-align: left;
  }

  .search-trigger-kbd {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 500;
    color: var(--fg-soft);
    background: var(--bg-hover);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 0.1rem 0.3rem;
    line-height: 1.2;
  }

  /* ── Dialog ── */
  .search-dialog {
    width: 90vw;
    max-width: 640px;
    max-height: 70vh;
    padding: 0;
    background: var(--bg-card);
    border: 1px solid var(--accent);
    border-radius: 14px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.3), 0 4px 16px rgba(0, 0, 0, 0.15), 0 0 0 3px rgba(201, 168, 76, 0.1);
    overflow: hidden;
    color: var(--fg);
    margin: auto;
    margin-top: 15vh;
  }

  .search-dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .search-dialog[open] {
    animation: modal-scale-in 0.15s ease;
  }

  .search-dialog[open]::backdrop {
    animation: modal-fade-in 0.15s ease;
  }

  /* ── Dialog header ── */
  .search-dialog-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 1.25rem;
    height: 3.25rem;
    border-bottom: 1px solid var(--line);
    position: relative;
  }

  .search-dialog-icon {
    flex-shrink: 0;
    color: var(--fg-soft);
  }

  .search-dialog-input {
    font-size: 1.5rem !important;
    font-weight: 300 !important;
    border: none !important;
    border-radius: 0 !important;
    background: transparent !important;
    padding: 0 !important;
    height: 100%;
    flex: 1;
  }

  .search-dialog-input:focus {
    border-color: transparent !important;
    box-shadow: none !important;
  }

  .search-dialog-kbd {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--fg-soft);
    background: var(--bg-hover);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 0.25rem 0.5rem;
    line-height: 1.2;
    flex-shrink: 0;
  }

  .search-dialog-close {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--fg-soft);
    cursor: pointer;
    font-size: 1rem;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    transition: color 0.15s ease, background 0.15s ease;
    font-family: var(--font-sans);
    padding: 0;
    line-height: 1;
    flex-shrink: 0;
  }

  .search-dialog-close:hover {
    color: var(--fg);
    background: var(--bg-hover);
  }

  /* ── Dialog body (results) ── */
  .search-dialog-body {
    max-height: calc(70vh - 3.25rem);
    overflow-y: auto;
    padding: 0.5rem;
  }

  .search-dialog-body::-webkit-scrollbar {
    width: 6px;
  }
  .search-dialog-body::-webkit-scrollbar-track {
    background: transparent;
  }
  .search-dialog-body::-webkit-scrollbar-thumb {
    background: var(--line);
    border-radius: 3px;
  }

  /* Larger result text in modal */
  .search-dialog-body :global(.search-result) {
    padding: 0.75rem 1rem;
  }

  .search-dialog-body :global(.search-result-link) {
    font-size: 0.92rem;
  }

  .search-dialog-body :global(.search-result-excerpt) {
    font-size: 0.84rem;
  }

  .search-dialog-body :global(.search-message) {
    padding: 0.25rem 1rem 0.5rem;
  }

  /* ── Animations ── */
  @keyframes modal-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes modal-scale-in {
    from { opacity: 0; transform: scale(0.96) translateY(-10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
</style>

<script>
  import { initPagefind, search } from "../lib/search-engine";
  import { renderResults, setupKeyboardNav, isMac } from "../lib/search-ui";

  const dialog = document.getElementById("search-dialog") as HTMLDialogElement;
  const triggers = document.querySelectorAll(".search-trigger");
  const input = dialog?.querySelector<HTMLInputElement>(".search-dialog-input");
  const kbdDialog = dialog?.querySelector<HTMLElement>(".search-dialog-kbd");
  const closeBtn = dialog?.querySelector<HTMLButtonElement>(".search-dialog-close");
  const resultsEl = dialog?.querySelector<HTMLElement>(".search-results");
  const messageEl = dialog?.querySelector<HTMLElement>(".search-message");
  const bodyEl = dialog?.querySelector<HTMLElement>(".search-dialog-body");

  let pagefindReady = false;

  // Set platform-specific shortcut text
  const shortcutText = isMac() ? "⌘K" : "Ctrl K";
  document.querySelectorAll(".search-trigger-kbd").forEach((el) => {
    el.textContent = shortcutText;
  });
  if (kbdDialog) kbdDialog.textContent = shortcutText;

  function openModal() {
    if (!dialog) return;
    dialog.showModal();
    if (!pagefindReady) {
      loadAndInit();
    } else {
      focusInput();
    }
  }

  function closeModal() {
    if (!dialog) return;
    dialog.close();
  }

  function focusInput() {
    setTimeout(() => {
      if (input) {
        input.focus();
        input.select();
      }
    }, 50);
  }

  async function loadAndInit() {
    const ok = await initPagefind();
    pagefindReady = ok;

    if (ok && input && resultsEl) {
      input.addEventListener("input", async () => {
        const query = input.value;
        // Toggle kbd badge vs close button
        if (kbdDialog) kbdDialog.hidden = !!query;
        if (closeBtn) closeBtn.hidden = !query;

        if (!query.trim()) {
          while (resultsEl.firstChild) resultsEl.removeChild(resultsEl.firstChild);
          if (messageEl) messageEl.hidden = true;
          if (bodyEl) bodyEl.hidden = true;
          return;
        }

        const results = await search(query);
        renderResults(resultsEl, results, messageEl || undefined);
        if (bodyEl) bodyEl.hidden = results.length === 0;
      });

      // Close button clears and resets
      if (closeBtn) {
        closeBtn.addEventListener("click", () => {
          input.value = "";
          if (kbdDialog) kbdDialog.hidden = false;
          closeBtn.hidden = true;
          while (resultsEl.firstChild) resultsEl.removeChild(resultsEl.firstChild);
          if (messageEl) messageEl.hidden = true;
          if (bodyEl) bodyEl.hidden = true;
          input.focus();
        });
      }

      setupKeyboardNav(input, resultsEl, closeModal);
    }

    focusInput();
  }

  // Trigger button clicks
  triggers.forEach((btn) => btn.addEventListener("click", openModal));

  // Backdrop click to close (native dialog fires cancel on Escape)
  dialog?.addEventListener("click", (e) => {
    if (e.target === dialog) closeModal();
  });

  dialog?.addEventListener("cancel", (e) => {
    e.preventDefault();
    closeModal();
  });

  // Cmd/Ctrl+K to toggle
  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      if (dialog?.open) {
        closeModal();
      } else {
        openModal();
      }
    }
  });
</script>
