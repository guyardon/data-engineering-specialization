---
---

<!-- Trigger button in sidebar -->
<button class="search-trigger" type="button" aria-label="Search">
  <svg class="search-trigger-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
  <span class="search-trigger-text">Search...</span>
  <kbd class="search-trigger-kbd">⌘K</kbd>
</button>

<!-- Modal overlay -->
<div class="search-modal-backdrop" id="search-modal-backdrop">
  <div class="search-modal" role="dialog" aria-modal="true" aria-label="Search">
    <button class="modal-clear" type="button" aria-label="Clear search">✕</button>
    <div id="modal-search" class="search-modal-inner" data-search-id="modal-search"></div>
  </div>
</div>

<style is:global>
  /* ── Trigger button ── */
  .search-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.5rem 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--fg-soft);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .search-trigger:hover {
    border-color: var(--accent);
    color: var(--fg-muted);
  }

  .search-trigger-icon {
    flex-shrink: 0;
  }

  .search-trigger-text {
    flex: 1;
    text-align: left;
  }

  .search-trigger-kbd {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 500;
    color: var(--fg-soft);
    background: var(--bg-hover);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 0.1rem 0.3rem;
    line-height: 1.2;
  }

  /* ── Modal backdrop ── */
  .search-modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    align-items: flex-start;
    justify-content: center;
    padding-top: 15vh;
  }

  .search-modal-backdrop.open {
    display: flex;
    animation: modal-fade-in 0.15s ease;
  }

  /* ── Modal card ── */
  .search-modal {
    width: 90vw;
    max-width: 640px;
    max-height: 70vh;
    background: var(--bg-card);
    border: 1px solid var(--accent);
    border-radius: 14px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.3), 0 4px 16px rgba(0, 0, 0, 0.15), 0 0 0 3px rgba(201, 168, 76, 0.1);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    animation: modal-scale-in 0.15s ease;
    position: relative;
  }

  .search-modal-inner {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    height: 100%;
  }

  /* ── Decorations on the card itself (immune to Pagefind DOM changes) ── */
  .search-modal::before {
    content: "";
    position: absolute;
    left: 1.25rem;
    top: calc(3.25rem / 2);
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    background: var(--fg-soft);
    -webkit-mask-image: url("data:image/svg+xml,%3Csvg width='20' height='20' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='11' cy='11' r='8' stroke='%23000' stroke-width='2'/%3E%3Cline x1='21' y1='21' x2='16.65' y2='16.65' stroke='%23000' stroke-width='2'/%3E%3C/svg%3E");
    mask-image: url("data:image/svg+xml,%3Csvg width='20' height='20' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='11' cy='11' r='8' stroke='%23000' stroke-width='2'/%3E%3Cline x1='21' y1='21' x2='16.65' y2='16.65' stroke='%23000' stroke-width='2'/%3E%3C/svg%3E");
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    pointer-events: none;
    z-index: 20;
  }

  .search-modal::after {
    content: "⌘K";
    position: absolute;
    right: 1rem;
    top: calc(3.25rem / 2);
    transform: translateY(-50%);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--fg-soft);
    background: var(--bg-hover);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 0.25rem 0.5rem;
    pointer-events: none;
    z-index: 20;
    line-height: 1.2;
  }

  .search-modal.non-mac::after {
    content: "Ctrl K";
  }

  /* Hide badge when input has text */
  .search-modal.has-query::after {
    display: none;
  }

  /* Clear button — replaces badge when input has text */
  .modal-clear {
    display: none;
    position: absolute;
    right: 1rem;
    top: calc(3.25rem / 2);
    transform: translateY(-50%);
    z-index: 20;
    background: none;
    border: none;
    color: var(--fg-soft);
    cursor: pointer;
    font-size: 1rem;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease, background 0.15s ease;
    font-family: var(--font-sans);
    padding: 0;
    line-height: 1;
  }

  .modal-clear:hover {
    color: var(--fg);
    background: var(--bg-hover);
  }

  .search-modal.has-query .modal-clear {
    display: flex;
  }

  /* ── Modal-specific overrides ── */
  /* All selectors use 3+ class specificity to beat global .pagefind-ui .pagefind-ui__* (0-2-0) */

  /* Hide Pagefind's built-in magnifying glass */
  .search-modal .pagefind-ui .pagefind-ui__form::before {
    display: none !important;
  }

  .search-modal .pagefind-ui .pagefind-ui__form {
    border-bottom: 1px solid var(--line) !important;
  }

  .search-modal .pagefind-ui .pagefind-ui__search-input {
    font-size: 1.5rem !important;
    font-weight: 300 !important;
    border: none !important;
    border-radius: 0 !important;
    background: transparent !important;
    padding: 0 4.5rem 0 4rem !important;
    height: 3.25rem !important;
    line-height: 3.25rem !important;
  }

  .search-modal .pagefind-ui .pagefind-ui__search-input:focus {
    border-color: transparent !important;
    box-shadow: none !important;
  }

  /* Hide Pagefind's clear button — we use our own */
  .search-modal .pagefind-ui .pagefind-ui__search-clear {
    display: none !important;
  }

  /* Drawer: static inside the card, not a floating dropdown */
  /* Needs 0-5-0 specificity to beat global :not(:has()) rule at 0-4-0 */
  .search-modal .search-modal-inner .pagefind-ui .pagefind-ui__drawer {
    position: static !important;
    border: none !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    max-height: calc(70vh - 80px) !important;
    overflow-y: auto !important;
    padding: 0.5rem !important;
    background: transparent !important;
  }

  /* Only show drawer when it has actual results */
  .search-modal .search-modal-inner .pagefind-ui .pagefind-ui__drawer:has(.pagefind-ui__result) {
    display: block !important;
  }

  .search-modal .search-modal-inner .pagefind-ui .pagefind-ui__drawer:not(:has(.pagefind-ui__result)) {
    display: none !important;
  }

  /* Larger result text in modal */
  .search-modal .pagefind-ui .pagefind-ui__result-nested a {
    font-size: 0.92rem !important;
  }

  .search-modal .pagefind-ui .pagefind-ui__result-nested {
    padding: 0.75rem 1rem !important;
    border-radius: 10px !important;
  }

  .search-modal .pagefind-ui .pagefind-ui__result-excerpt {
    font-size: 0.84rem !important;
  }

  .search-modal .pagefind-ui .pagefind-ui__message {
    padding: 0.25rem 1rem 0.5rem !important;
  }

  /* Animations */
  @keyframes modal-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes modal-scale-in {
    from { opacity: 0; transform: scale(0.96); }
    to { opacity: 1; transform: scale(1); }
  }
</style>

<script>
  const backdrop = document.getElementById("search-modal-backdrop");
  const triggers = document.querySelectorAll(".search-trigger");
  let pagefindLoaded = false;

  function openModal() {
    if (!backdrop) return;
    backdrop.classList.add("open");
    document.body.style.overflow = "hidden";

    if (!pagefindLoaded) {
      loadPagefindInModal();
      pagefindLoaded = true;
    } else {
      focusInput();
    }
  }

  function closeModal() {
    if (!backdrop) return;
    backdrop.classList.remove("open");
    document.body.style.overflow = "";
  }

  function focusInput() {
    setTimeout(() => {
      const input = backdrop?.querySelector(".pagefind-ui__search-input");
      if (input) {
        input.focus();
        input.select();
      }
    }, 50);
  }

  function initPagefindModal() {
    if (window.PagefindUI) {
        new window.PagefindUI({
          element: "#modal-search",
          bundlePath: "/data-engineering-specialization-website/pagefind/",
          baseUrl: "/data-engineering-specialization-website/",
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          excerptLength: 30,
        });

        setTimeout(() => {
          const input = backdrop?.querySelector(".pagefind-ui__search-input");
          const modal = backdrop?.querySelector(".search-modal");
          const clearBtn = backdrop?.querySelector(".modal-clear");

          if (input && modal) {
            input.placeholder = "Search...";

            // Toggle has-query class for ⌘K ↔ ✕ swap
            input.addEventListener("input", () => {
              modal.classList.toggle("has-query", !!input.value);
            });

            // Our clear button clears input and triggers Pagefind reset
            if (clearBtn) {
              clearBtn.addEventListener("click", () => {
                input.value = "";
                input.dispatchEvent(new Event("input", { bubbles: true }));
                modal.classList.remove("has-query");
                input.focus();
              });
            }
          }

          // Add keyboard navigation
          if (input) {
            let activeIndex = -1;

            function getResults() {
              return Array.from(backdrop?.querySelectorAll(".pagefind-ui__result-nested") || []);
            }

            function setActive(results, index) {
              results.forEach((r) => r.classList.remove("kb-active"));
              activeIndex = index;
              if (index >= 0 && index < results.length) {
                results[index].classList.add("kb-active");
                results[index].scrollIntoView({ block: "nearest" });
              }
            }

            input.addEventListener("keydown", (e) => {
              if (e.key === "Escape") {
                e.preventDefault();
                closeModal();
                return;
              }

              const results = getResults();
              if (!results.length) return;

              if (e.key === "ArrowDown") {
                e.preventDefault();
                setActive(results, Math.min(activeIndex + 1, results.length - 1));
              } else if (e.key === "ArrowUp") {
                e.preventDefault();
                setActive(results, Math.max(activeIndex - 1, 0));
              } else if (e.key === "Enter" && activeIndex >= 0) {
                e.preventDefault();
                const link = results[activeIndex].querySelector("a");
                if (link) link.click();
              }
            });

            const observer = new MutationObserver(() => { activeIndex = -1; });
            const drawer = backdrop?.querySelector(".pagefind-ui__drawer");
            if (drawer) observer.observe(drawer, { childList: true, subtree: true });
          }

          focusInput();
        }, 200);
      }
  }

  function loadPagefindInModal() {
    if (window.PagefindUI) {
      initPagefindModal();
      return;
    }
    const script = document.createElement("script");
    script.src = "/data-engineering-specialization-website/pagefind/pagefind-ui.js";
    script.onload = initPagefindModal;
    script.onerror = () => { focusInput(); };
    document.head.appendChild(script);
  }

  // Trigger button clicks
  triggers.forEach((btn) => btn.addEventListener("click", openModal));

  // Backdrop click to close
  backdrop?.addEventListener("click", (e) => {
    if (e.target === backdrop) closeModal();
  });

  // Cmd/Ctrl+K to toggle
  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      if (backdrop?.classList.contains("open")) {
        closeModal();
      } else {
        openModal();
      }
    }
  });

  // Escape to close (for clicks outside input)
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && backdrop?.classList.contains("open")) {
      closeModal();
    }
  });

  // Show Ctrl K on non-Mac
  if (!/Mac|iPhone|iPad/.test(navigator.platform)) {
    document.querySelectorAll(".search-trigger-kbd").forEach((el) => {
      el.textContent = "Ctrl K";
    });
    // Update CSS ::after badge for modal
    document.querySelector(".search-modal")?.classList.add("non-mac");
  }
</script>
