---
import { BASE } from "../lib/base";
const { size = "default", label = "DE Specialization" } = Astro.props;
const isHome = label === "Home";
const iconSize = size === "large" ? "28" : isHome ? "18" : "20";
---

<a
  href={`${BASE}/`}
  class={`logo logo--${size} ${isHome ? "logo--home" : ""}`}
  aria-label="Home"
>
  {
    isHome ? (
      <svg
        width={iconSize}
        height={iconSize}
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="logo-icon"
      >
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
        <polyline points="9 22 9 12 15 12 15 22" />
      </svg>
    ) : (
      <svg
        width={iconSize}
        height={iconSize}
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="logo-icon"
      >
        <polyline points="4 17 10 11 4 5" />
        <line x1="12" y1="19" x2="20" y2="19" />
      </svg>
    )
  }
  {!isHome && <span class="logo-text">{label}</span>}
</a>

<style>
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--fg);
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }
  .logo:hover {
    color: var(--accent);
  }
  .logo-icon {
    flex-shrink: 0;
    color: var(--accent);
  }
  .logo-text {
    font-family: var(--font-serif);
    font-weight: 600;
    line-height: 1.3;
  }
  .logo--default .logo-text {
    font-size: 0.9rem;
  }
  .logo--large .logo-text {
    font-size: clamp(1.5rem, 3vw, 2rem);
  }

  .logo--home {
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .logo--home .logo-icon {
    color: var(--fg-muted);
  }
  .logo--home:hover {
    border-color: var(--accent);
  }
  .logo--home:hover .logo-icon {
    color: var(--accent);
  }
</style>
