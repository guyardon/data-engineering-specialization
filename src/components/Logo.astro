---
import { BASE } from "../lib/base";
const { size = "default" } = Astro.props;
const iconSize = size === "large" ? "28" : "20";
---

<a href={`${BASE}/`} class={`logo logo--${size}`}>
  <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="logo-icon">
    <polyline points="4 17 10 11 4 5"></polyline>
    <line x1="12" y1="19" x2="20" y2="19"></line>
  </svg>
  <span class="logo-text">DE Specialization</span>
</a>

<style>
  .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: var(--fg); transition: color 0.15s ease; }
  .logo:hover { color: var(--accent); }
  .logo-icon { flex-shrink: 0; color: var(--accent); }
  .logo-text { font-family: var(--font-serif); font-weight: 600; line-height: 1.3; }
  .logo--default .logo-text { font-size: 0.9rem; }
  .logo--large .logo-text { font-size: clamp(1.5rem, 3vw, 2rem); }
</style>
