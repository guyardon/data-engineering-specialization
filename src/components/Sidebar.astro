---
import { getCollection } from "astro:content";
import { BASE } from "../lib/base";
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
import SearchModal from "./SearchModal.astro";

const notes = await getCollection("notes");
const currentSlug = Astro.props.currentSlug as string;

// Build navigation tree
type NoteItem = {
  slug: string;
  title: string;
  order: number;
};
type WeekItem = {
  title: string;
  slug: string;
  order: number;
  notes: NoteItem[];
};
type CourseItem = {
  title: string;
  slug: string;
  order: number;
  weeks: Map<string, WeekItem>;
};

const courseEmojis: Record<string, string> = {
  "course-1-introduction-to-data-engineering": "\u{1F4CA}",
  "course-2-source-systems-data-ingestion-and-pipelines": "\u{1F50C}",
  "course-3-data-storage-and-queries": "\u{1F5C4}",
  "course-4-data-modeling-transformation-and-serving": "\u{2699}",
};

// Per-note emoji for flat view, keyed by last path segment of the note id
const noteEmojis: Record<string, string> = {
  // Course 1
  "11-how-to-think-like-a-data-engineer": "\u{1F914}",
  "12-data-engineering-on-the-cloud": "\u{2601}\u{FE0F}",
  "21-the-data-engineering-lifecycle": "\u{1F501}",
  "22-introduction-to-the-undercurrents": "\u{1F30A}",
  "23-practical-examples-on-aws": "\u{1F6E0}\u{FE0F}",
  "31-introduction-to-data-architecture": "\u{1F3D7}\u{FE0F}",
  "32-choosing-the-right-technologies": "\u{1F9F0}",
  "33-investigating-your-architecture-on-aws": "\u{1F50D}",
  "41-stakeholder-management-and-gathering-requirements": "\u{1F465}",
  "42-aws-services-for-batch-pipelines": "\u{1F4E6}",
  "43-aws-services-for-streaming-pipelines": "\u{26A1}",
  // Course 2
  "11-introduction-to-source-systems": "\u{1F50C}",
  "12-connecting-to-source-systems": "\u{1F517}",
  "21-data-ingestion-patterns": "\u{1F4E5}",
  "22-etl-vs-elt": "\u{2194}\u{FE0F}",
  "23-streaming-systems": "\u{1F30A}",
  "24-change-data-capture": "\u{1F4F8}",
  "31-dataops-automation": "\u{1F916}",
  "32-data-observability-and-monitoring": "\u{1F4E1}",
  "41-orchestration-overview": "\u{1F3BC}",
  "42-airflow-ui-and-dag-creation": "\u{1F4A8}",
  "43-airflow-taskflow-api": "\u{1F9E9}",
  // Course 3
  "11-storage-fundamentals": "\u{1F4BE}",
  "12-storage-tiers-and-distributed-systems": "\u{1F5C2}\u{FE0F}",
  "13-storage-in-databases": "\u{1F5C3}\u{FE0F}",
  "14-specialized-databases": "\u{1F9EC}",
  "21-data-warehouses": "\u{1F3E2}",
  "22-data-lakes": "\u{1F3DE}\u{FE0F}",
  "23-data-lakehouse": "\u{1F3E1}",
  "24-aws-data-lakehouse": "\u{1F3DD}\u{FE0F}",
  "31-batch-queries": "\u{1F4CB}",
  "32-query-performance-and-advanced-sql": "\u{1F3CE}\u{FE0F}",
  "33-joins-aggregations-and-redshift": "\u{1F500}",
  "34-streaming-queries": "\u{1F300}",
  // Course 4
  "11-data-modeling-fundamentals": "\u{1F4D0}",
  "12-normalization": "\u{1F9EE}",
  "13-dimensional-modeling-and-star-schema": "\u{2B50}",
  "14-modeling-approaches-and-dbt": "\u{1F9F1}",
  "21-tabular-data-for-machine-learning": "\u{1F4CA}",
  "22-unstructured-data-for-machine-learning": "\u{1F5BC}\u{FE0F}",
  "31-batch-transformation-patterns": "\u{1F504}",
  "32-hadoop": "\u{1F418}",
  "33-spark-and-dataframes": "\u{2728}",
  "34-pyspark-sql-emr-glue-and-streaming": "\u{1F525}",
  "41-serving-data-and-analytics": "\u{1F4E1}",
};

const weekEmojis: Record<string, string> = {
  "week-1-how-to-think-like-a-data-engineer": "\u{1F914}",
  "week-2-the-data-engineering-lifecycle-undercurrents": "\u{1F504}",
  "week-3-data-architecture": "\u{1F3D7}",
  "week-4-translating-requirements-to-architecture": "\u{1F4DD}",
  "week-1-working-with-source-systems": "\u{1F517}",
  "week-2-data-digestion": "\u{1F4E5}",
  "week-3-dataops": "\u{2699}",
  "week-4-orchestration-monitoring-and-automating-your-data-pip": "\u{1F3BC}",
  "week-1-data-storage-deep-dive": "\u{1F4BE}",
  "week-2-storage-abstractions": "\u{1F4E6}",
  "week-3-queries": "\u{1F50D}",
  "week-1-data-modeling-transformations-for-analytics": "\u{1F4D0}",
  "week-2-data-modeling-transformations-for-machine-learning": "\u{1F916}",
  "week-3-data-transformations-technical-considerations": "\u{26A1}",
  "week-4-serving-data-and-analytics-for-machine-learning": "\u{1F4E1}",
};

const tree = new Map<string, CourseItem>();

for (const note of notes) {
  const {
    course,
    courseSlug,
    courseOrder,
    week,
    weekSlug,
    weekOrder,
    order,
    title,
  } = note.data;

  if (!tree.has(courseSlug)) {
    tree.set(courseSlug, {
      title: course,
      slug: courseSlug,
      order: courseOrder,
      weeks: new Map(),
    });
  }
  const courseNode = tree.get(courseSlug)!;

  if (!courseNode.weeks.has(weekSlug)) {
    courseNode.weeks.set(weekSlug, {
      title: week,
      slug: weekSlug,
      order: weekOrder,
      notes: [],
    });
  }
  courseNode.weeks.get(weekSlug)!.notes.push({ slug: note.id, title, order });
}

// Sort everything
const courses = Array.from(tree.values()).sort((a, b) => a.order - b.order);
for (const course of courses) {
  course.weeks = new Map(
    Array.from(course.weeks.entries()).sort(
      ([, a], [, b]) => a.order - b.order,
    ),
  );
  for (const week of course.weeks.values()) {
    week.notes.sort((a, b) => a.order - b.order);
  }
}

// Determine which course/week the current note belongs to
const currentNote = notes.find((n) => n.id === currentSlug);
const activeCourseSlug = currentNote?.data.courseSlug;
const activeWeekSlug = currentNote?.data.weekSlug;

// Flat view: all notes in reading order (courseOrder → weekOrder → order)
const flatNotes = [...notes].sort((a, b) => {
  if (a.data.courseOrder !== b.data.courseOrder)
    return a.data.courseOrder - b.data.courseOrder;
  if (a.data.weekOrder !== b.data.weekOrder)
    return a.data.weekOrder - b.data.weekOrder;
  return a.data.order - b.data.order;
});
---

<nav id="sidebar" class="sidebar" aria-label="Course navigation">
  <div class="sidebar-header">
    <Logo label="Home" />
    <div class="sidebar-header-actions">
      <ThemeToggle />
      <button
        id="sidebar-close"
        class="sidebar-close-btn"
        aria-label="Close sidebar"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <div class="sidebar-search">
    <SearchModal />
    <a href={`${BASE}/glossary/`} class="sidebar-glossary-link"
      >📖 Glossary of Terms</a
    >
  </div>

  <div class="view-toggle" role="group" aria-label="Sidebar view mode">
    <button
      type="button"
      class="view-toggle-btn"
      data-view-target="grouped"
      aria-pressed="true"
    >
      Grouped
    </button>
    <button
      type="button"
      class="view-toggle-btn"
      data-view-target="flat"
      aria-pressed="false"
    >
      Flat
    </button>
  </div>

  <div class="nav-flat">
    <ul class="flat-list">
      {
        flatNotes.map((note, idx) => {
          const isActive = note.id === currentSlug;
          const prev = flatNotes[idx - 1];
          const showCourseSep =
            !prev || prev.data.courseSlug !== note.data.courseSlug;
          const leafSlug = note.id.split("/").pop() || note.id;
          const emoji = noteEmojis[leafSlug] || "📄";
          return (
            <>
              {showCourseSep && (
                <li class="flat-course-sep" aria-hidden="true">
                  {note.data.course}
                </li>
              )}
              <li>
                <a
                  href={`${BASE}/notes/${note.id}/`}
                  class={`flat-link ${isActive ? "active" : ""}`}
                >
                  <span class="flat-emoji" aria-hidden="true">
                    {emoji}
                  </span>
                  <span class="flat-title">
                    {note.data.title.replace(/^\d+\.\d+\s+/, "")}
                  </span>
                </a>
              </li>
            </>
          );
        })
      }
    </ul>
  </div>

  <div class="nav-tree">
    {
      courses.map((course) => {
        const isCourseActive = course.slug === activeCourseSlug;
        const weeks = Array.from(course.weeks.values());
        return (
          <details class="course-details">
            <summary class={`course-summary ${isCourseActive ? "active" : ""}`}>
              <span class="summary-text">
                <span class="nav-emoji">{courseEmojis[course.slug] || ""}</span>{" "}
                {course.title}
              </span>
              <span class="chevron">▸</span>
            </summary>
            <div class="course-content">
              {weeks.map((week) => {
                const isWeekActive =
                  isCourseActive && week.slug === activeWeekSlug;
                return (
                  <details class="week-details">
                    <summary
                      class={`week-summary ${isWeekActive ? "active" : ""}`}
                    >
                      <span class="summary-text">
                        <span class="nav-emoji">
                          {weekEmojis[week.slug] || ""}
                        </span>{" "}
                        {week.title}
                      </span>
                      <span class="chevron">▸</span>
                    </summary>
                    <ul class="note-list">
                      {week.notes.map((note) => {
                        const isActive = note.slug === currentSlug;
                        return (
                          <li>
                            <a
                              href={`${BASE}/notes/${note.slug}/`}
                              class={`note-link ${isActive ? "active" : ""}`}
                            >
                              {note.title}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </details>
                );
              })}
            </div>
          </details>
        );
      })
    }
  </div>
</nav>

<style>
  .sidebar {
    width: 280px;
    min-width: 280px;
    height: 100vh;
    position: sticky;
    top: 0;
    overflow-y: auto;
    background-color: var(--bg);
    border-right: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1rem 0.75rem;
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    background-color: var(--bg);
    z-index: 1;
  }

  .sidebar-header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .sidebar-close-btn {
    display: none;
    background: none;
    border: none;
    color: var(--fg-soft);
    cursor: pointer;
    font-size: 1rem;
    padding: 0.25rem;
  }

  .nav-tree {
    padding: 0.5rem 0;
    flex: 1;
  }

  .nav-emoji {
    font-size: 1.1em;
    margin-right: 0.1rem;
  }

  /* Course level */
  .course-details {
    border-bottom: 1px solid var(--line);
  }

  .course-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 1rem;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 600;
    font-family: var(--font-sans);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    list-style: none;
    user-select: none;
  }

  .course-summary::-webkit-details-marker {
    display: none;
  }
  .course-summary::marker {
    display: none;
  }

  .course-summary:hover {
    color: var(--fg);
    background-color: var(--bg-hover);
  }
  .course-summary.active {
    color: var(--accent);
  }

  .course-details[open] > .course-summary .chevron {
    transform: rotate(90deg);
  }

  .chevron {
    font-size: 0.65rem;
    transition: transform 0.15s ease;
    flex-shrink: 0;
  }

  .summary-text {
    flex: 1;
  }

  .course-content {
    padding-bottom: 0.25rem;
  }

  /* Week level */
  .week-details {
  }

  .week-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4rem 1rem 0.4rem 1.25rem;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 500;
    font-family: var(--font-sans);
    color: var(--fg-soft);
    list-style: none;
    user-select: none;
  }

  .week-summary::-webkit-details-marker {
    display: none;
  }
  .week-summary::marker {
    display: none;
  }

  .week-summary:hover {
    color: var(--fg-muted);
    background-color: var(--bg-hover);
  }
  .week-summary.active {
    color: var(--fg-muted);
  }

  .week-details[open] > .week-summary .chevron {
    transform: rotate(90deg);
  }

  /* Note links */
  .note-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .note-link {
    display: block;
    padding: 0.3rem 1rem 0.3rem 2rem;
    font-size: 0.8rem;
    font-family: var(--font-sans);
    color: var(--fg-soft);
    text-decoration: none;
    line-height: 1.4;
    border-left: 2px solid transparent;
  }

  .note-link:hover {
    color: var(--fg);
    background-color: var(--bg-hover);
    border-left-color: var(--line-strong);
  }

  .note-link.active {
    color: var(--accent);
    background-color: var(--bg-hover);
    border-left-color: var(--accent);
    font-weight: 500;
  }

  .sidebar-glossary-link {
    display: block;
    font-size: 0.78rem;
    font-weight: 500;
    font-family: var(--font-sans);
    color: var(--fg-muted);
    text-decoration: none;
    text-align: center;
    margin-top: 0.5rem;
    padding: 0.3rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .sidebar-glossary-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .sidebar-search {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--line);
  }

  /* View toggle (Grouped / Flat) */
  .view-toggle {
    display: flex;
    gap: 2px;
    margin: 0.5rem 0.75rem;
    padding: 2px;
    background-color: var(--bg-hover);
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .view-toggle-btn {
    flex: 1;
    padding: 0.3rem 0.5rem;
    background: transparent;
    border: none;
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--fg-muted);
    cursor: pointer;
    transition:
      background-color 0.15s ease,
      color 0.15s ease;
  }

  .view-toggle-btn:hover {
    color: var(--fg);
  }

  /* Visual "selected" state is driven by the html data attribute (set before
     paint via the inline head script) so the correct button is highlighted
     on first render, with no flash. */
  :global(html[data-sidebar-view="flat"])
    .view-toggle-btn[data-view-target="flat"],
  :global(html:not([data-sidebar-view="flat"]))
    .view-toggle-btn[data-view-target="grouped"] {
    background-color: var(--bg);
    color: var(--accent);
    box-shadow: 0 1px 2px rgb(0 0 0 / 0.12);
  }

  /* Visibility gate based on current view mode (set on <html> via inline
     head script so it applies before the browser paints — no flicker). */
  :global(html[data-sidebar-view="flat"]) .nav-tree {
    display: none;
  }
  :global(html:not([data-sidebar-view="flat"])) .nav-flat {
    display: none;
  }

  /* Flat view */
  .nav-flat {
    padding: 0.25rem 0 0.5rem;
    flex: 1;
  }

  .flat-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .flat-link {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.4rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    text-decoration: none;
    line-height: 1.35;
    color: var(--fg-soft);
    border-left: 2px solid transparent;
  }

  .flat-link .flat-emoji {
    font-size: 1em;
    flex-shrink: 0;
    line-height: 1;
  }

  .flat-link .flat-title {
    flex: 1;
    min-width: 0;
  }

  .flat-link:hover {
    color: var(--fg);
    background-color: var(--bg-hover);
    border-left-color: var(--line-strong);
  }

  .flat-link.active {
    color: var(--accent);
    background-color: var(--bg-hover);
    border-left-color: var(--accent);
    font-weight: 500;
  }

  .flat-course-sep {
    padding: 0.75rem 1rem 0.3rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-muted);
    border-top: 1px solid var(--line);
    margin-top: 0.25rem;
  }

  .flat-list > .flat-course-sep:first-child {
    border-top: none;
    margin-top: 0;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      left: -300px;
      top: 0;
      z-index: 50;
      width: 280px;
      transition: left 0.2s ease;
      box-shadow: 4px 0 20px rgb(0 0 0 / 0.5);
    }

    .sidebar.open {
      left: 0;
    }
    .sidebar-close-btn {
      display: block;
    }
  }
</style>

<script>
  const TREE_KEY = "sidebar-tree-state";
  const VIEW_KEY = "sidebar-view-mode";
  const sidebar = document.getElementById("sidebar");

  function currentMode(): "flat" | "grouped" {
    return document.documentElement.getAttribute("data-sidebar-view") === "flat"
      ? "flat"
      : "grouped";
  }

  // Reflect the saved view on the toggle buttons.
  const initialMode = currentMode();
  document.querySelectorAll(".view-toggle-btn").forEach((btn) => {
    const target = btn.getAttribute("data-view-target");
    btn.setAttribute("aria-pressed", target === initialMode ? "true" : "false");
  });

  // View toggle click handler
  document.querySelectorAll(".view-toggle-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.getAttribute("data-view-target");
      if (!target) return;
      document.documentElement.setAttribute("data-sidebar-view", target);
      localStorage.setItem(VIEW_KEY, target);
      document.querySelectorAll(".view-toggle-btn").forEach((b) => {
        b.setAttribute(
          "aria-pressed",
          b.getAttribute("data-view-target") === target ? "true" : "false",
        );
      });
      setTimeout(centerActive, 0);
    });
  });

  function saveTreeState() {
    const state: Record<string, boolean> = {};
    document.querySelectorAll(".course-details").forEach((course, ci) => {
      state["c" + ci] = course.hasAttribute("open");
      course.querySelectorAll(".week-details").forEach((week, wi) => {
        state["c" + ci + "w" + wi] = week.hasAttribute("open");
      });
    });
    localStorage.setItem(TREE_KEY, JSON.stringify(state));
  }

  // Restore tree state from localStorage.
  const saved = localStorage.getItem(TREE_KEY);
  if (saved) {
    try {
      const state = JSON.parse(saved);
      document.querySelectorAll(".course-details").forEach((course, ci) => {
        if (state["c" + ci]) course.setAttribute("open", "");
        course.querySelectorAll(".week-details").forEach((week, wi) => {
          if (state["c" + ci + "w" + wi]) week.setAttribute("open", "");
        });
      });
    } catch {
      // Ignore corrupted storage.
    }
  }

  // Make sure the active note is reachable in grouped view — open its
  // course + week even if the user had collapsed them previously.
  const activeNoteLink = document.querySelector(".note-link.active");
  if (activeNoteLink) {
    let node: Element | null = activeNoteLink;
    while (node) {
      if (
        node instanceof HTMLElement &&
        (node.classList.contains("course-details") ||
          node.classList.contains("week-details"))
      ) {
        node.setAttribute("open", "");
      }
      node = node.parentElement;
    }
  }

  // Center the active row of the current view in the sidebar scroll area.
  function centerActive() {
    if (!sidebar) return;
    const sel =
      currentMode() === "flat" ? ".flat-link.active" : ".note-link.active";
    const active = sidebar.querySelector(sel) as HTMLElement | null;
    if (!active) return;
    active.scrollIntoView({ block: "center", behavior: "auto" });
  }

  // Run after layout settles. requestAnimationFrame doesn't fire when the
  // tab is not visible (common under headless preview), so use setTimeout.
  setTimeout(() => {
    centerActive();
    // Reveal the sidebar list once scroll position is correct — the critical
    // inline CSS in the head keeps it invisible until this flag flips, so
    // the user never sees the scrollbar jump from top to its final spot.
    document.documentElement.setAttribute("data-sidebar-ready", "");
  }, 0);

  // Save state on toggle and collapse weeks when closing a course
  document.querySelectorAll(".course-details").forEach((course) => {
    course.querySelector(".course-summary")?.addEventListener("click", () => {
      requestAnimationFrame(() => {
        if (!course.hasAttribute("open")) {
          course.querySelectorAll(".week-details").forEach((week) => {
            week.removeAttribute("open");
          });
        }
        saveTreeState();
      });
    });
    course.querySelectorAll(".week-details").forEach((week) => {
      week.querySelector(".week-summary")?.addEventListener("click", () => {
        requestAnimationFrame(() => saveTreeState());
      });
    });
  });
</script>
