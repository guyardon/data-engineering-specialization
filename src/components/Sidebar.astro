---
import { getCollection } from "astro:content";
import { BASE } from "../lib/base";
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
import SearchModal from "./SearchModal.astro";

const notes = await getCollection("notes");
const currentSlug = Astro.props.currentSlug as string;

// Build navigation tree
type NoteItem = {
  slug: string;
  title: string;
  order: number;
};
type WeekItem = {
  title: string;
  slug: string;
  order: number;
  notes: NoteItem[];
};
type CourseItem = {
  title: string;
  slug: string;
  order: number;
  weeks: Map<string, WeekItem>;
};

const courseEmojis: Record<string, string> = {
  "course-1-introduction-to-data-engineering": "\u{1F4CA}",
  "course-2-source-systems-data-ingestion-and-pipelines": "\u{1F50C}",
  "course-3-data-storage-and-queries": "\u{1F5C4}",
  "course-4-data-modeling-transformation-and-serving": "\u{2699}",
};

const weekEmojis: Record<string, string> = {
  "week-1-how-to-think-like-a-data-engineer": "\u{1F914}",
  "week-2-the-data-engineering-lifecycle-undercurrents": "\u{1F504}",
  "week-3-data-architecture": "\u{1F3D7}",
  "week-4-translating-requirements-to-architecture": "\u{1F4DD}",
  "week-1-working-with-source-systems": "\u{1F517}",
  "week-2-data-digestion": "\u{1F4E5}",
  "week-3-dataops": "\u{2699}",
  "week-4-orchestration-monitoring-and-automating-your-data-pip": "\u{1F3BC}",
  "week-1-data-storage-deep-dive": "\u{1F4BE}",
  "week-2-storage-abstractions": "\u{1F4E6}",
  "week-3-queries": "\u{1F50D}",
  "week-1-data-modeling-transformations-for-analytics": "\u{1F4D0}",
  "week-2-data-modeling-transformations-for-machine-learning": "\u{1F916}",
  "week-3-data-transformations-technical-considerations": "\u{26A1}",
  "week-4-serving-data-and-analytics-for-machine-learning": "\u{1F4E1}",
};

const tree = new Map<string, CourseItem>();

for (const note of notes) {
  const {
    course,
    courseSlug,
    courseOrder,
    week,
    weekSlug,
    weekOrder,
    order,
    title,
  } = note.data;

  if (!tree.has(courseSlug)) {
    tree.set(courseSlug, {
      title: course,
      slug: courseSlug,
      order: courseOrder,
      weeks: new Map(),
    });
  }
  const courseNode = tree.get(courseSlug)!;

  if (!courseNode.weeks.has(weekSlug)) {
    courseNode.weeks.set(weekSlug, {
      title: week,
      slug: weekSlug,
      order: weekOrder,
      notes: [],
    });
  }
  courseNode.weeks.get(weekSlug)!.notes.push({ slug: note.id, title, order });
}

// Sort everything
const courses = Array.from(tree.values()).sort((a, b) => a.order - b.order);
for (const course of courses) {
  course.weeks = new Map(
    Array.from(course.weeks.entries()).sort(
      ([, a], [, b]) => a.order - b.order,
    ),
  );
  for (const week of course.weeks.values()) {
    week.notes.sort((a, b) => a.order - b.order);
  }
}

// Determine which course/week the current note belongs to
const currentNote = notes.find((n) => n.id === currentSlug);
const activeCourseSlug = currentNote?.data.courseSlug;
const activeWeekSlug = currentNote?.data.weekSlug;
---

<nav id="sidebar" class="sidebar" aria-label="Course navigation">
  <div class="sidebar-header">
    <Logo />
    <div class="sidebar-header-actions">
      <ThemeToggle />
      <button id="sidebar-close" class="sidebar-close-btn" aria-label="Close sidebar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <div class="sidebar-search">
    <SearchModal />
    <a href={`${BASE}/glossary/`} class="sidebar-glossary-link">📖 Glossary of Terms</a>
  </div>

  <div class="nav-tree">
    {
      courses.map((course) => {
        const isCourseActive = course.slug === activeCourseSlug;
        const weeks = Array.from(course.weeks.values());
        return (
          <details open={isCourseActive} class="course-details">
            <summary class={`course-summary ${isCourseActive ? "active" : ""}`}>
              <span class="summary-text"><span class="nav-emoji">{courseEmojis[course.slug] || ""}</span> {course.title}</span>
              <span class="chevron">▸</span>
            </summary>
            <div class="course-content">
              {weeks.map((week) => {
                const isWeekActive =
                  isCourseActive && week.slug === activeWeekSlug;
                return (
                  <details open={isWeekActive} class="week-details">
                    <summary
                      class={`week-summary ${isWeekActive ? "active" : ""}`}
                    >
                      <span class="summary-text"><span class="nav-emoji">{weekEmojis[week.slug] || ""}</span> {week.title}</span>
                      <span class="chevron">▸</span>
                    </summary>
                    <ul class="note-list">
                      {week.notes.map((note) => {
                        const isActive = note.slug === currentSlug;
                        return (
                          <li>
                            <a
                              href={`${BASE}/notes/${note.slug}/`}
                              class={`note-link ${isActive ? "active" : ""}`}
                            >
                              {note.title}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </details>
                );
              })}
            </div>
          </details>
        );
      })
    }
  </div>
</nav>

<style>
  .sidebar {
    width: 280px;
    min-width: 280px;
    height: 100vh;
    position: sticky;
    top: 0;
    overflow-y: auto;
    background-color: var(--bg);
    border-right: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1rem 0.75rem;
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    background-color: var(--bg);
    z-index: 1;
  }

  .sidebar-header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .sidebar-close-btn {
    display: none;
    background: none;
    border: none;
    color: var(--fg-soft);
    cursor: pointer;
    font-size: 1rem;
    padding: 0.25rem;
  }

  .nav-tree {
    padding: 0.5rem 0;
    flex: 1;
  }

  .nav-emoji {
    font-size: 1.1em;
    margin-right: 0.1rem;
  }

  /* Course level */
  .course-details {
    border-bottom: 1px solid var(--line);
  }

  .course-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 1rem;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 600;
    font-family: var(--font-sans);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    list-style: none;
    user-select: none;
  }

  .course-summary::-webkit-details-marker {
    display: none;
  }
  .course-summary::marker {
    display: none;
  }

  .course-summary:hover {
    color: var(--fg);
    background-color: var(--bg-hover);
  }
  .course-summary.active {
    color: var(--accent);
  }

  .course-details[open] > .course-summary .chevron {
    transform: rotate(90deg);
  }

  .chevron {
    font-size: 0.65rem;
    transition: transform 0.15s ease;
    flex-shrink: 0;
  }

  .summary-text {
    flex: 1;
  }

  .course-content {
    padding-bottom: 0.25rem;
  }

  /* Week level */
  .week-details {
  }

  .week-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4rem 1rem 0.4rem 1.25rem;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 500;
    font-family: var(--font-sans);
    color: var(--fg-soft);
    list-style: none;
    user-select: none;
  }

  .week-summary::-webkit-details-marker {
    display: none;
  }
  .week-summary::marker {
    display: none;
  }

  .week-summary:hover {
    color: var(--fg-muted);
    background-color: var(--bg-hover);
  }
  .week-summary.active {
    color: var(--fg-muted);
  }

  .week-details[open] > .week-summary .chevron {
    transform: rotate(90deg);
  }

  /* Note links */
  .note-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .note-link {
    display: block;
    padding: 0.3rem 1rem 0.3rem 2rem;
    font-size: 0.8rem;
    font-family: var(--font-sans);
    color: var(--fg-soft);
    text-decoration: none;
    line-height: 1.4;
    border-left: 2px solid transparent;
  }

  .note-link:hover {
    color: var(--fg);
    background-color: var(--bg-hover);
    border-left-color: var(--line-strong);
  }

  .note-link.active {
    color: var(--accent);
    background-color: var(--bg-hover);
    border-left-color: var(--accent);
    font-weight: 500;
  }

  .sidebar-glossary-link {
    display: block;
    font-size: 0.78rem;
    font-weight: 500;
    font-family: var(--font-sans);
    color: var(--fg-muted);
    text-decoration: none;
    text-align: center;
    margin-top: 0.5rem;
    padding: 0.3rem;
    border-radius: 8px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .sidebar-glossary-link:hover {
    color: var(--accent);
    background-color: var(--bg-hover);
  }

  .sidebar-search {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--line);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      left: -300px;
      top: 0;
      z-index: 50;
      width: 280px;
      transition: left 0.2s ease;
      box-shadow: 4px 0 20px rgb(0 0 0 / 0.5);
    }

    .sidebar.open {
      left: 0;
    }
    .sidebar-close-btn {
      display: block;
    }
  }
</style>


<script>
  document.querySelectorAll(".course-details").forEach((course) => {
    course.querySelector(".course-summary")?.addEventListener("click", (e) => {
      // After the browser toggles the course details, sync all week details
      requestAnimationFrame(() => {
        const isOpen = course.hasAttribute("open");
        course.querySelectorAll(".week-details").forEach((week) => {
          if (isOpen) {
            week.setAttribute("open", "");
          } else {
            week.removeAttribute("open");
          }
        });
      });
    });
  });
</script>
