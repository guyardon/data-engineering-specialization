---
export interface Heading {
  depth: number;
  slug: string;
  text: string;
}

const { headings } = Astro.props as { headings: Heading[] };
const filtered = headings.filter((h) => h.depth === 2);
---

{
  filtered.length > 1 && (
    <nav class="toc" aria-label="Table of contents">
      <p class="toc-title">On this page</p>
      <ul class="toc-list">
        {filtered.map((h) => (
          <li class={`toc-item depth-${h.depth}`}>
            <a href={`#${h.slug}`} class="toc-link">
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  .toc {
    position: sticky;
    top: 1.5rem;
    max-height: calc(100vh - 3rem);
    overflow-y: auto;
    padding: 0 0.5rem;
    min-width: 200px;
    max-width: 220px;
  }

  .toc-title {
    font-size: 0.75rem;
    font-weight: 600;
    font-family: var(--font-sans);
    color: var(--fg-soft);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 1px solid var(--line);
  }

  .toc-item {
    margin: 0;
  }

  .toc-link {
    display: block;
    padding: 0.2rem 0.75rem;
    font-size: 0.78rem;
    font-family: var(--font-sans);
    color: var(--fg-soft);
    text-decoration: none;
    line-height: 1.4;
    transition: color 0.1s;
  }

  .toc-link:hover {
    color: var(--fg);
  }

  .depth-2 .toc-link {
    padding-left: 0.75rem;
  }
  .depth-3 .toc-link {
    padding-left: 1.5rem;
    font-size: 0.75rem;
  }

  .toc-link.active {
    color: var(--accent);
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>(".toc-link");
  const headingEls = Array.from(links)
    .map((l) => {
      const id = l.getAttribute("href")?.slice(1);
      return id ? document.getElementById(id) : null;
    })
    .filter(Boolean) as HTMLElement[];

  function onScroll() {
    let active = headingEls[0];
    for (const el of headingEls) {
      if (el.getBoundingClientRect().top < 120) active = el;
    }
    links.forEach((l) => {
      l.classList.toggle("active", l.getAttribute("href") === `#${active?.id}`);
    });
  }

  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
