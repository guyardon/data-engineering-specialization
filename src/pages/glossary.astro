---
import "../styles/global.css";
import { BASE } from "../lib/base";
import { getCollection } from "astro:content";
import Logo from "../components/Logo.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import SearchBar from "../components/SearchBar.astro";
import glossaryData from "../data/glossary.json";

const notes = await getCollection("notes");
const noteMap = new Map(notes.map((n) => [n.id, n.data.title]));

// Validate all slugs at build time
for (const category of glossaryData) {
  for (const term of category.terms) {
    for (const ref of term.notes) {
      if (!noteMap.has(ref.slug)) {
        throw new Error(`Glossary: invalid slug "${ref.slug}" for term "${term.term}"`);
      }
    }
  }
}

// Sort terms alphabetically within each category
for (const category of glossaryData) {
  category.terms.sort((a, b) => a.term.localeCompare(b.term));
}

// Build resolved data for client-side use (resolve slugs to titles at build time)
const resolvedData = glossaryData.map((cat) => ({
  ...cat,
  terms: cat.terms.map((term) => ({
    ...term,
    notes: term.notes.map((ref) => ({
      ...ref,
      title: noteMap.get(ref.slug) as string,
      href: `${BASE}/notes/${ref.slug}/${ref.anchor ?? ""}`,
    })),
  })),
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Glossary of Terms — Data Engineering Specialization</title>
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    <script is:inline>
      (function() {
        var saved = localStorage.getItem("theme");
        if (saved === "light") {
          document.documentElement.setAttribute("data-theme", "light");
        } else if (!saved && window.matchMedia("(prefers-color-scheme: light)").matches) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
  </head>
  <body>
    <div class="glossary-page">
      <header class="home-topbar">
        <Logo label="Home" />
        <div class="home-topbar-actions">
          <SearchBar />
          <ThemeToggle />
        </div>
      </header>

      <section class="glossary-hero">
        <h1 class="glossary-title">Glossary of Terms</h1>
        <p class="glossary-subtitle">
          Key concepts and technologies covered across all four courses.
        </p>
      </section>

      <div class="glossary-layout">
        <nav class="category-nav" aria-label="Browse by category">
          {glossaryData.map((cat, i) => (
            <button class="pill category-pill" data-category={i}>
              {cat.icon} {cat.category}
            </button>
          ))}
          <button class="pill category-pill" data-category="all">📋 Show All</button>
        </nav>

        <section id="terms-section" class="terms-section hidden">
          <div id="terms-pills" class="terms-pills"></div>
        </section>

        <section id="detail-section" class="detail-section hidden">
          <div id="detail-card" class="detail-card"></div>
        </section>
      </div>

      <dialog id="detail-modal" class="detail-modal">
        <button class="detail-modal-close" aria-label="Close">&times;</button>
        <div id="detail-modal-card" class="detail-card"></div>
      </dialog>

      <dialog id="lightbox" class="lightbox">
        <button class="lightbox-close" aria-label="Close">&times;</button>
        <img id="lightbox-img-light" class="lightbox-img diagram-light" alt="" />
        <img id="lightbox-img-dark" class="lightbox-img diagram-dark" alt="" />
      </dialog>

      <!-- Hidden data for Pagefind indexing -->
      <div class="sr-only" data-pagefind-body>
        {resolvedData.map((cat) => (
          <div>
            <h2>{cat.icon} {cat.category}</h2>
            {cat.terms.map((term) => (
              <p data-pagefind-weight="2">{term.term}</p>
            ))}
          </div>
        ))}
      </div>

      <footer class="glossary-footer">
        <p>Built with Astro. Notes from the DeepLearning.AI Data Engineering Specialization on Coursera.</p>
      </footer>
    </div>

    <script define:vars={{ resolvedData, BASE }}>
      const data = resolvedData;
      const basePath = BASE;
      const termsPills = document.getElementById("terms-pills");
      const termsSection = document.getElementById("terms-section");
      const detailCard = document.getElementById("detail-card");
      const detailSection = document.getElementById("detail-section");
      const detailModal = document.getElementById("detail-modal");
      const detailModalCard = document.getElementById("detail-modal-card");
      const detailModalClose = detailModal.querySelector(".detail-modal-close");

      const categoryNav = document.querySelector(".category-nav");
      function isMobile() { return window.innerWidth <= 768; }

      let activeCategory = null;
      let activeTerm = null;

      function clearChildren(el) {
        while (el.firstChild) el.removeChild(el.firstChild);
      }

      const allTerms = [];
      data.forEach((cat, ci) => {
        cat.terms.forEach((term, ti) => {
          allTerms.push({ term, ci, ti });
        });
      });
      allTerms.sort((a, b) => a.term.term.localeCompare(b.term.term));

      document.querySelectorAll(".category-pill").forEach((btn) => {
        btn.addEventListener("click", () => {
          const raw = btn.dataset.category;
          const key = raw === "all" ? "all" : parseInt(raw);

          if (activeCategory === key) {
            activeCategory = null;
            activeTerm = null;
            btn.classList.remove("active");
            categoryNav.classList.remove("has-selection");
            termsSection.classList.add("hidden");
            detailSection.classList.add("hidden");
            return;
          }

          document.querySelectorAll(".category-pill.active").forEach((b) => b.classList.remove("active"));
          activeCategory = key;
          activeTerm = null;
          btn.classList.add("active");
          categoryNav.classList.add("has-selection");
          detailSection.classList.add("hidden");

          clearChildren(termsPills);
          const terms = key === "all" ? allTerms : data[key].terms.map((term, ti) => ({ term, ci: key, ti }));
          terms.forEach((entry) => {
            const pill = document.createElement("button");
            pill.className = "pill term-pill";
            pill.textContent = entry.term.term;
            pill.addEventListener("click", () => handleTermClick(entry.ci, entry.ti, pill));
            termsPills.appendChild(pill);
          });
          termsSection.classList.remove("hidden");
        });
      });

      function buildExpandSvg() {
        const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
        svg.setAttribute("width", "16"); svg.setAttribute("height", "16");
        svg.setAttribute("viewBox", "0 0 24 24"); svg.setAttribute("fill", "none");
        svg.setAttribute("stroke", "currentColor"); svg.setAttribute("stroke-width", "2");
        svg.setAttribute("stroke-linecap", "round"); svg.setAttribute("stroke-linejoin", "round");
        const pts = [["15 3 21 3 21 9"], ["9 21 3 21 3 15"]];
        pts.forEach(function(p) { const pl = document.createElementNS("http://www.w3.org/2000/svg", "polyline"); pl.setAttribute("points", p[0]); svg.appendChild(pl); });
        const lines = [["21","3","14","10"],["3","21","10","14"]];
        lines.forEach(function(l) { const ln = document.createElementNS("http://www.w3.org/2000/svg", "line"); ln.setAttribute("x1",l[0]); ln.setAttribute("y1",l[1]); ln.setAttribute("x2",l[2]); ln.setAttribute("y2",l[3]); svg.appendChild(ln); });
        return svg;
      }

      function buildTermDetail(target, term) {
        clearChildren(target);

        const title = document.createElement("h3");
        title.className = "detail-title";
        title.textContent = term.term;
        target.appendChild(title);

        if (term.description) {
          const desc = document.createElement("p");
          desc.className = "detail-desc";
          desc.textContent = term.description;
          target.appendChild(desc);
        }

        if (term.diagram) {
          const isPng = term.diagram.endsWith(".png");
          const baseName = isPng ? term.diagram.replace(".png", "") : term.diagram;
          const ext = isPng ? "png" : "svg";

          const lightSrc = basePath + "/images/diagrams/" + baseName + "." + ext;
          const darkSrc = basePath + "/images/diagrams/" + baseName + "-dark." + ext;

          const diagramWrap = document.createElement("div");
          diagramWrap.className = "detail-diagram";

          const expandBtn = document.createElement("button");
          expandBtn.className = "diagram-expand";
          expandBtn.setAttribute("aria-label", "Enlarge diagram");
          expandBtn.appendChild(buildExpandSvg());
          expandBtn.addEventListener("click", function() { openLightbox(lightSrc, darkSrc, term.term); });
          diagramWrap.appendChild(expandBtn);

          const imgLight = document.createElement("img");
          imgLight.src = lightSrc;
          imgLight.alt = term.term;
          imgLight.className = "diagram diagram-light";
          diagramWrap.appendChild(imgLight);

          const imgDark = document.createElement("img");
          imgDark.src = darkSrc;
          imgDark.alt = term.term;
          imgDark.className = "diagram diagram-dark";
          diagramWrap.appendChild(imgDark);

          target.appendChild(diagramWrap);
        }

        const seeMore = document.createElement("div");
        seeMore.className = "detail-see-more";

        const label = document.createElement("span");
        label.className = "detail-label";
        label.textContent = "See more at:";
        seeMore.appendChild(label);

        const links = document.createElement("div");
        links.className = "detail-links";
        term.notes.forEach(function(ref) {
          const a = document.createElement("a");
          a.href = ref.href;
          a.className = "pill note-card";
          a.textContent = ref.title;
          links.appendChild(a);
        });
        seeMore.appendChild(links);
        target.appendChild(seeMore);

        // Related terms
        if (term.relatedTerms && term.relatedTerms.length > 0) {
          const relatedSection = document.createElement("div");
          relatedSection.className = "detail-related";

          const relatedLabel = document.createElement("span");
          relatedLabel.className = "detail-label";
          relatedLabel.textContent = "Related terms:";
          relatedSection.appendChild(relatedLabel);

          const relatedLinks = document.createElement("div");
          relatedLinks.className = "detail-links";
          term.relatedTerms.forEach(function(relatedName) {
            // Find the related term in the data
            var found = null;
            data.forEach(function(cat, ci) {
              cat.terms.forEach(function(t, ti) {
                if (t.term === relatedName) found = { term: t, ci: ci, ti: ti };
              });
            });
            if (!found) return;

            const btn = document.createElement("button");
            btn.className = "pill related-term-pill";
            btn.textContent = relatedName;
            btn.addEventListener("click", function() {
              activeTerm = found.ci + "-" + found.ti;

              // Update active term pill in background
              document.querySelectorAll(".term-pill.active").forEach(function(b) { b.classList.remove("active"); });
              var matchedPill = null;
              termsPills.querySelectorAll(".term-pill").forEach(function(p) {
                if (p.textContent === relatedName) { p.classList.add("active"); matchedPill = p; }
              });

              // Scroll terms section to center on the pill (desktop only)
              if (matchedPill && !isMobile()) {
                var container = termsSection;
                var pillTop = matchedPill.offsetTop - container.offsetTop;
                var pillHeight = matchedPill.offsetHeight;
                var containerHeight = container.clientHeight;
                container.scrollTo({ top: pillTop - (containerHeight / 2) + (pillHeight / 2), behavior: "smooth" });
              }

              buildTermDetail(target, found.term);
            });
            relatedLinks.appendChild(btn);
          });
          relatedSection.appendChild(relatedLinks);
          target.appendChild(relatedSection);
        }

        // Shuffle button
        {
          const shuffleWrap = document.createElement("div");
          shuffleWrap.className = "detail-shuffle";

          const shuffleBtn = document.createElement("button");
          shuffleBtn.className = "pill shuffle-btn";
          shuffleBtn.setAttribute("aria-label", "Random term");

          const shuffleSvg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
          shuffleSvg.setAttribute("width", "14"); shuffleSvg.setAttribute("height", "14");
          shuffleSvg.setAttribute("viewBox", "0 0 24 24"); shuffleSvg.setAttribute("fill", "none");
          shuffleSvg.setAttribute("stroke", "currentColor"); shuffleSvg.setAttribute("stroke-width", "2");
          shuffleSvg.setAttribute("stroke-linecap", "round"); shuffleSvg.setAttribute("stroke-linejoin", "round");
          var p1 = document.createElementNS("http://www.w3.org/2000/svg", "polyline");
          p1.setAttribute("points", "16 3 21 3 21 8"); shuffleSvg.appendChild(p1);
          var l1 = document.createElementNS("http://www.w3.org/2000/svg", "line");
          l1.setAttribute("x1","4"); l1.setAttribute("y1","20"); l1.setAttribute("x2","21"); l1.setAttribute("y2","3"); shuffleSvg.appendChild(l1);
          var p2 = document.createElementNS("http://www.w3.org/2000/svg", "polyline");
          p2.setAttribute("points", "21 16 21 21 16 21"); shuffleSvg.appendChild(p2);
          var l2 = document.createElementNS("http://www.w3.org/2000/svg", "line");
          l2.setAttribute("x1","15"); l2.setAttribute("y1","15"); l2.setAttribute("x2","21"); l2.setAttribute("y2","21"); shuffleSvg.appendChild(l2);
          var l3 = document.createElementNS("http://www.w3.org/2000/svg", "line");
          l3.setAttribute("x1","4"); l3.setAttribute("y1","4"); l3.setAttribute("x2","9"); l3.setAttribute("y2","9"); shuffleSvg.appendChild(l3);

          shuffleBtn.appendChild(shuffleSvg);
          var shuffleText = document.createElement("span");
          shuffleText.textContent = "Shuffle";
          shuffleBtn.appendChild(shuffleText);

          shuffleBtn.addEventListener("click", function() {
            var pool = activeCategory === "all" ? allTerms : data[activeCategory].terms.map(function(t, ti) { return { term: t, ci: activeCategory, ti: ti }; });
            if (pool.length <= 1) return;
            var pick;
            do {
              pick = pool[Math.floor(Math.random() * pool.length)];
            } while (pick.ci + "-" + pick.ti === activeTerm && pool.length > 1);
            activeTerm = pick.ci + "-" + pick.ti;

            // Update active term pill in background
            document.querySelectorAll(".term-pill.active").forEach(function(b) { b.classList.remove("active"); });
            var activePill = null;
            var termPills = termsPills.querySelectorAll(".term-pill");
            termPills.forEach(function(p) {
              if (p.textContent === pick.term.term) { p.classList.add("active"); activePill = p; }
            });

            // Scroll terms section to center on the selected pill (without moving the page)
            if (activePill && !isMobile()) {
              var container = termsSection;
              var pillTop = activePill.offsetTop - container.offsetTop;
              var pillHeight = activePill.offsetHeight;
              var containerHeight = container.clientHeight;
              container.scrollTo({ top: pillTop - (containerHeight / 2) + (pillHeight / 2), behavior: "smooth" });
            }

            buildTermDetail(target, pick.term);
          });

          shuffleWrap.appendChild(shuffleBtn);
          target.appendChild(shuffleWrap);
        }
      }

      function handleTermClick(ci, ti, pill) {
        const key = ci + "-" + ti;
        if (activeTerm === key) {
          activeTerm = null;
          pill.classList.remove("active");
          detailSection.classList.add("hidden");
          return;
        }

        document.querySelectorAll(".term-pill.active").forEach(function(b) { b.classList.remove("active"); });
        activeTerm = key;
        pill.classList.add("active");

        const term = data[ci].terms[ti];

        if (isMobile()) {
          buildTermDetail(detailModalCard, term);
          detailModal.showModal();
        } else {
          buildTermDetail(detailCard, term);
          detailSection.classList.remove("hidden");
        }
      }

      // Detail modal close
      detailModalClose.addEventListener("click", function() { detailModal.close(); });
      detailModal.addEventListener("click", function(e) {
        if (e.target === detailModal) detailModal.close();
      });

      // Lightbox
      const lightbox = document.getElementById("lightbox");
      const lbImgLight = document.getElementById("lightbox-img-light");
      const lbImgDark = document.getElementById("lightbox-img-dark");
      const lbClose = lightbox.querySelector(".lightbox-close");

      function openLightbox(lightSrc, darkSrc, alt) {
        lbImgLight.src = lightSrc;
        lbImgLight.alt = alt;
        lbImgDark.src = darkSrc;
        lbImgDark.alt = alt;
        lightbox.showModal();
      }

      lbClose.addEventListener("click", () => lightbox.close());
      lightbox.addEventListener("click", (e) => {
        if (e.target === lightbox) lightbox.close();
      });

      // Auto-select "Show All" on page load
      const showAllBtn = document.querySelector('.category-pill[data-category="all"]');
      if (showAllBtn) showAllBtn.click();
    </script>
  </body>
</html>

<style is:global>
/* Pill styles need is:global because JS creates elements dynamically without Astro scoping */
.pill { font-family: var(--font-sans); font-size: 0.78rem; font-weight: 500; color: var(--fg-muted); background: var(--bg-card); border: 1px solid var(--line); border-radius: 20px; padding: 0.35rem 0.75rem; cursor: pointer; white-space: nowrap; transition: border-color 0.15s ease, color 0.15s ease, background-color 0.15s ease; }
.pill:hover { color: var(--accent); border-color: var(--accent); }
.pill.active { color: var(--accent); border-color: var(--accent); background-color: color-mix(in srgb, var(--accent) 10%, transparent); }
.pill.note-card { text-decoration: none; }
.terms-pills, .detail-links { display: flex; flex-wrap: wrap; gap: 0.4rem; justify-content: center; }
.detail-card { position: relative; }
.detail-shuffle { position: absolute; top: clamp(0.75rem, 2vw, 1rem); right: clamp(0.75rem, 2vw, 1rem); }
.shuffle-btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.35rem 0.7rem; font-size: 0.78rem; }
.shuffle-btn:hover { color: var(--accent); border-color: var(--accent); }
.hidden { display: none; }

/* Detail card */
.detail-card { background: var(--bg-card); border: 1px solid var(--line); border-radius: 14px; padding: clamp(1rem, 2vw, 1.5rem); }
.detail-title { font-family: var(--font-serif); font-size: 1.15rem; font-weight: 600; color: var(--fg); margin-bottom: 0.75rem; padding-right: 5.5rem; }
.detail-desc { font-family: var(--font-sans); font-size: 0.88rem; color: var(--fg-muted); line-height: 1.65; margin-bottom: 1rem; }
.detail-diagram { margin-bottom: 1rem; text-align: center; position: relative; }
.diagram-expand { position: absolute; top: 0.4rem; right: 0.4rem; background: var(--bg-card); border: 1px solid var(--line); color: var(--fg-soft); width: 1.75rem; height: 1.75rem; border-radius: 6px; cursor: pointer; display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.15s ease, color 0.15s ease, border-color 0.15s ease; }
.detail-diagram:hover .diagram-expand { opacity: 1; }
.diagram-expand:hover { color: var(--accent); border-color: var(--accent); }
.detail-diagram img { max-width: 100%; max-height: 400px; object-fit: contain; border-radius: 8px; }
.detail-diagram img.diagram-dark { display: none; }
:root:not([data-theme="light"]) .detail-diagram img.diagram-dark { display: inline; }
:root:not([data-theme="light"]) .detail-diagram img.diagram-light { display: none; }
.detail-see-more { border-top: 1px solid var(--line); padding-top: 0.75rem; }
.detail-related { border-top: 1px solid var(--line); padding-top: 0.75rem; margin-top: 0.75rem; }
.detail-label { display: block; font-family: var(--font-sans); font-size: 0.75rem; font-weight: 600; color: var(--fg-soft); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; text-align: center; }

/* Lightbox */
.lightbox { border: none; background: var(--bg-card); max-width: 90vw; max-height: 90vh; padding: 1.5rem; border-radius: 16px; box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3); position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); margin: 0; }
.lightbox::backdrop { background: rgba(0, 0, 0, 0.4); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
.lightbox .lightbox-img { max-width: 85vw; max-height: 80vh; object-fit: contain; border-radius: 10px; display: block; }
.lightbox .lightbox-close { position: absolute; top: 0.5rem; right: 0.5rem; background: none; color: var(--fg-soft); border: none; font-size: 1.5rem; width: 2rem; height: 2rem; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: color 0.15s ease, background 0.15s ease; }
.lightbox .lightbox-close:hover { color: var(--fg); background: var(--bg-hover); }
.lightbox .lightbox-close:focus { outline: none; }
.lightbox .diagram-dark { display: none; }
:root:not([data-theme="light"]) .lightbox .diagram-dark { display: inline; }
:root:not([data-theme="light"]) .lightbox .diagram-light { display: none; }

/* Detail modal (mobile) */
.detail-modal { border: none; background: var(--bg-card); width: 90vw; max-width: 90vw; max-height: 85vh; padding: 1.5rem; border-radius: 16px; box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3); position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); margin: 0; overflow-y: auto; }
.detail-modal::backdrop { background: rgba(0, 0, 0, 0.4); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
.detail-modal .detail-modal-close { position: absolute; top: 0.5rem; right: 0.5rem; background: none; color: var(--fg-soft); border: none; font-size: 1.5rem; width: 2rem; height: 2rem; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: color 0.15s ease, background 0.15s ease; }
.detail-modal .detail-modal-close:hover { color: var(--fg); background: var(--bg-hover); }
.detail-modal .detail-modal-close:focus { outline: none; }
.detail-modal .diagram-dark { display: none; }
:root:not([data-theme="light"]) .detail-modal .diagram-dark { display: inline; }
:root:not([data-theme="light"]) .detail-modal .diagram-light { display: none; }
</style>

<style>
.glossary-page { max-width: 1200px; margin: 0 auto; padding: clamp(1.5rem, 3vw, 2.5rem); min-height: 100vh; display: flex; flex-direction: column; }
.home-topbar { display: flex; align-items: center; justify-content: space-between; padding-bottom: 2rem; border-bottom: 1px solid var(--line); margin-bottom: 2rem; }
.home-topbar-actions { display: flex; align-items: center; gap: 0.5rem; }

.glossary-hero { text-align: center; margin-bottom: 1.5rem; }
.glossary-title { font-family: var(--font-serif); font-size: clamp(1.8rem, 4vw, 2.5rem); font-weight: 700; color: var(--fg); margin-bottom: 0.5rem; line-height: 1.2; }
.glossary-subtitle { font-family: var(--font-sans); font-size: clamp(0.9rem, 2vw, 1rem); color: var(--fg-muted); line-height: 1.6; }

/* Three-column horizontal layout */
.glossary-layout { display: flex; gap: 1rem; margin-bottom: 2rem; align-items: flex-start; }
.category-nav { display: flex; flex-wrap: wrap; gap: 0.4rem; flex-shrink: 0; width: 33%; position: sticky; top: 1rem; align-content: flex-start; max-height: calc(100vh - 2rem); overflow-y: auto; }
.terms-section { flex: 1; min-width: 0; position: sticky; top: 1rem; max-height: calc(100vh - 2rem); overflow-y: auto; }
.detail-section { flex: 1; min-width: 0; position: sticky; top: 1rem; max-height: calc(100vh - 2rem); overflow-y: auto; }
.category-nav::-webkit-scrollbar, .terms-section::-webkit-scrollbar, .detail-section::-webkit-scrollbar { display: none; }
.category-nav, .terms-section, .detail-section { scrollbar-width: none; }

@media (max-width: 768px) {
  .glossary-layout { flex-direction: column; gap: 1.5rem; }
  .category-nav { flex-direction: row; flex-wrap: wrap; width: auto; position: static; justify-content: center; }
  .category-nav.has-selection { padding-bottom: 1.5rem; border-bottom: 1px solid var(--line); }
  .detail-section { position: static; display: none; }
}

.sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }

.glossary-footer { margin-top: auto; padding-top: 2rem; border-top: 1px solid var(--line); text-align: center; }
