---
import "../styles/global.css";
import { BASE } from "../lib/base";
import { getCollection } from "astro:content";
import Logo from "../components/Logo.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import SearchBar from "../components/SearchBar.astro";
import glossaryData from "../data/glossary.json";

const notes = await getCollection("notes");
const noteMap = new Map(notes.map((n) => [n.id, n.data.title]));

// Validate all slugs at build time
for (const category of glossaryData) {
  for (const term of category.terms) {
    for (const ref of term.notes) {
      if (!noteMap.has(ref.slug)) {
        throw new Error(
          `Glossary: invalid slug "${ref.slug}" for term "${term.term}"`,
        );
      }
    }
  }
}

// Sort terms alphabetically within each category
for (const category of glossaryData) {
  category.terms.sort((a, b) => a.term.localeCompare(b.term));
}

// Build resolved data for client-side use (resolve slugs to titles at build time)
const resolvedData = glossaryData.map((cat) => ({
  ...cat,
  terms: cat.terms.map((term) => ({
    ...term,
    notes: term.notes.map((ref) => ({
      ...ref,
      title: noteMap.get(ref.slug) as string,
      href: `${BASE}/notes/${ref.slug}/${ref.anchor ?? ""}`,
    })),
  })),
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Glossary of Terms — Data Engineering Specialization</title>
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    <script is:inline>
      (function () {
        const saved = localStorage.getItem("theme");
        if (saved === "light") {
          document.documentElement.setAttribute("data-theme", "light");
        } else if (
          !saved &&
          window.matchMedia("(prefers-color-scheme: light)").matches
        ) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
  </head>
  <body>
    <div class="glossary-page">
      <header class="home-topbar">
        <Logo label="Home" />
        <div class="home-topbar-actions">
          <SearchBar />
          <ThemeToggle />
        </div>
      </header>

      <section class="glossary-hero">
        <h1 class="glossary-title">Glossary of Terms</h1>
        <p class="glossary-subtitle">
          Key concepts and technologies covered across all four courses.
        </p>
      </section>

      <div class="glossary-layout">
        <div class="category-section">
          <button
            id="cat-prev"
            class="cat-nav cat-prev nav-hidden"
            aria-label="Previous categories"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <nav
            id="category-nav"
            class="category-nav"
            aria-label="Browse by category"
          >
            <button class="pill category-pill" data-category="all"
              >📋 Show All</button
            >
            {
              glossaryData.map((cat, i) => (
                <button class="pill category-pill" data-category={i}>
                  {cat.icon} {cat.category}
                </button>
              ))
            }
          </nav>
          <button
            id="cat-next"
            class="cat-nav cat-next nav-hidden"
            aria-label="Next categories"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="9 6 15 12 9 18"></polyline>
            </svg>
          </button>
        </div>

        <section id="terms-section" class="terms-section hidden">
          <button
            id="terms-prev"
            class="terms-nav terms-prev nav-hidden"
            aria-label="Previous page"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <div class="terms-viewport">
            <div id="terms-track" class="terms-track">
              <div id="terms-pills" class="terms-pills"></div>
            </div>
          </div>
          <button
            id="terms-next"
            class="terms-nav terms-next nav-hidden"
            aria-label="Next page"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="9 6 15 12 9 18"></polyline>
            </svg>
          </button>
        </section>

        <section id="detail-section" class="detail-section hidden">
          <div id="detail-card" class="detail-card"></div>
        </section>
      </div>

      <dialog id="detail-modal" class="detail-modal">
        <button class="detail-modal-close" aria-label="Close">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
        <div id="detail-modal-card" class="detail-card"></div>
      </dialog>

      <dialog id="lightbox" class="lightbox">
        <button class="lightbox-close" aria-label="Close">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
        <img
          id="lightbox-img-light"
          class="lightbox-img diagram-light"
          alt=""
        />
        <img id="lightbox-img-dark" class="lightbox-img diagram-dark" alt="" />
      </dialog>

      <!-- Hidden data for Pagefind indexing -->
      <div class="sr-only" data-pagefind-body>
        {
          resolvedData.map((cat) => (
            <div>
              <h2>
                {cat.icon} {cat.category}
              </h2>
              {cat.terms.map((term) => (
                <p data-pagefind-weight="2">{term.term}</p>
              ))}
            </div>
          ))
        }
      </div>

      <footer class="glossary-footer">
        <p>
          Built with Astro. Notes from the DeepLearning.AI Data Engineering
          Specialization on Coursera.
        </p>
      </footer>
    </div>

    <script define:vars={{ resolvedData, BASE }}>
      window.__glossaryData = resolvedData;
      window.__glossaryBasePath = BASE;
    </script>
    <script>
      import {
        buildAllTerms,
        getTermsForCategory,
        pickRandomTerm,
        termKey,
        type GlossaryCategory,
        type TermEntry,
      } from "../lib/glossary-data";
      import {
        computePageBreaks,
        findPageForIndex,
        getPageRange,
      } from "../lib/glossary-pagination";
      import { buildDetailCard } from "../lib/glossary-detail";

      const data = (window as unknown as Record<string, unknown>)
        .__glossaryData as GlossaryCategory[];
      const basePath = (window as unknown as Record<string, unknown>)
        .__glossaryBasePath as string;

      // --- DOM refs ---
      const termsPills = document.getElementById("terms-pills")!;
      const termsSection = document.getElementById("terms-section")!;
      const detailSection = document.getElementById("detail-section")!;
      const detailModal = document.getElementById(
        "detail-modal",
      ) as HTMLDialogElement;
      const detailModalCard = document.getElementById("detail-modal-card")!;
      const detailModalClose = detailModal.querySelector(
        ".detail-modal-close",
      )!;
      const categoryNav = document.getElementById("category-nav")!;
      const catPrev = document.getElementById("cat-prev")!;
      const catNext = document.getElementById("cat-next")!;
      const termsPrev = document.getElementById("terms-prev")!;
      const termsNext = document.getElementById("terms-next")!;
      const lightbox = document.getElementById("lightbox") as HTMLDialogElement;
      const lbImgLight = document.getElementById(
        "lightbox-img-light",
      ) as HTMLImageElement;
      const lbImgDark = document.getElementById(
        "lightbox-img-dark",
      ) as HTMLImageElement;
      const lbClose = lightbox.querySelector(".lightbox-close")!;

      function isMobile() {
        return window.innerWidth <= 768;
      }
      function clearChildren(el: Element) {
        while (el.firstChild) el.removeChild(el.firstChild);
      }

      const MAX_ROWS = 7;

      // --- State ---
      let activeCategory: "all" | number | null = null;
      let activeTerm: string | null = null;
      let currentTerms: TermEntry[] = [];
      let currentPage = 0;
      let pageBreaks: number[] = [0];
      let catPageBreaks: number[] = [0];
      let catCurrentPage = 0;

      // --- Computed data ---
      const allTerms = buildAllTerms(data);
      const allCatPills = Array.from(
        categoryNav.querySelectorAll(".category-pill"),
      ) as HTMLElement[];

      // --- DOM measurement helpers ---
      function countRows(container: Element): number {
        const children = container.children;
        if (children.length === 0) return 0;
        let rows = 1;
        let prevTop = (children[0] as HTMLElement).offsetTop;
        for (let i = 1; i < children.length; i++) {
          const top = (children[i] as HTMLElement).offsetTop;
          if (top > prevTop) {
            rows++;
            prevTop = top;
          }
        }
        return rows;
      }

      // --- Category pagination ---
      function buildCatPages() {
        const catSection = document.querySelector(".category-section")!;
        allCatPills.forEach((p) => {
          p.style.display = "";
        });

        catPageBreaks = computePageBreaks(
          allCatPills.length,
          (_start, count) => {
            // Show first `count` pills from _start, measure
            allCatPills.forEach((p, i) => {
              p.style.display = i >= _start && i < _start + count ? "" : "none";
            });
            return countRows(categoryNav) <= MAX_ROWS;
          },
        );

        if (catPageBreaks.length <= 1) {
          allCatPills.forEach((p) => {
            p.style.display = "";
          });
          catSection.classList.remove("paginated");
          catPrev.classList.add("nav-hidden");
          catNext.classList.add("nav-hidden");
        } else {
          catSection.classList.add("paginated");
          catCurrentPage = 0;
          renderCatPage();
        }
      }

      function renderCatPage() {
        const [start, end] = getPageRange(
          catPageBreaks,
          catCurrentPage,
          allCatPills.length,
        );
        allCatPills.forEach((p, i) => {
          p.style.display = i >= start && i < end ? "" : "none";
        });
        catPrev.classList.toggle("nav-hidden", catCurrentPage <= 0);
        catNext.classList.toggle(
          "nav-hidden",
          catCurrentPage >= catPageBreaks.length - 1,
        );
      }

      catPrev.addEventListener("click", () => {
        if (catCurrentPage > 0) {
          catCurrentPage--;
          renderCatPage();
        }
      });
      catNext.addEventListener("click", () => {
        if (catCurrentPage < catPageBreaks.length - 1) {
          catCurrentPage++;
          renderCatPage();
        }
      });

      // --- Terms pagination ---
      const termsTrack = document.getElementById("terms-track")!;

      const termsViewport = termsTrack.parentElement!;

      function buildTermsPages() {
        // Reset track and use termsPills as measurement container
        clearChildren(termsTrack);
        termsTrack.style.transform = "";
        termsTrack.style.transition = "";
        termsTrack.appendChild(termsPills);
        clearChildren(termsPills);

        // Add paginated class BEFORE measuring so the narrower width
        // (with nav arrow padding) is used during row counting.
        termsSection.classList.add("paginated");

        pageBreaks = computePageBreaks(currentTerms.length, (_start, count) => {
          clearChildren(termsPills);
          for (let i = _start; i < _start + count; i++) {
            const pill = document.createElement("button");
            pill.className = "pill term-pill";
            pill.textContent = currentTerms[i].term.term;
            termsPills.appendChild(pill);
          }
          return countRows(termsPills) <= MAX_ROWS;
        });

        clearChildren(termsPills);
        if (pageBreaks.length <= 1) {
          termsSection.classList.remove("paginated");
          termsPrev.classList.add("nav-hidden");
          termsNext.classList.add("nav-hidden");
        }
      }

      function renderAllPages() {
        clearChildren(termsTrack);
        for (let pg = 0; pg < pageBreaks.length; pg++) {
          const [start, end] = getPageRange(
            pageBreaks,
            pg,
            currentTerms.length,
          );
          const page = document.createElement("div");
          page.className = "terms-pills";
          for (let i = start; i < end; i++) {
            const entry = currentTerms[i];
            const pill = document.createElement("button");
            pill.className = "pill term-pill";
            if (activeTerm === termKey(entry.ci, entry.ti))
              pill.classList.add("active");
            pill.textContent = entry.term.term;
            pill.addEventListener("click", () =>
              handleTermClick(entry.ci, entry.ti, pill),
            );
            page.appendChild(pill);
          }
          termsTrack.appendChild(page);
        }
        scrollToPage(false);
      }

      function scrollToPage(animate = true) {
        const vpWidth = termsViewport.clientWidth;
        const offset = currentPage * vpWidth;
        const prefersReduced = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        termsTrack.style.transition =
          animate && !prefersReduced ? "transform 0.35s ease" : "none";
        // Use pixels since percentage would resolve against the track width
        termsTrack.style.transform = `translateX(-${offset}px)`;
        termsPrev.classList.toggle("nav-hidden", currentPage <= 0);
        termsNext.classList.toggle(
          "nav-hidden",
          currentPage >= pageBreaks.length - 1,
        );
      }

      function renderAllTerms() {
        clearChildren(termsTrack);
        const page = document.createElement("div");
        page.className = "terms-pills";
        currentTerms.forEach((entry) => {
          const pill = document.createElement("button");
          pill.className = "pill term-pill";
          if (activeTerm === termKey(entry.ci, entry.ti))
            pill.classList.add("active");
          pill.textContent = entry.term.term;
          pill.addEventListener("click", () =>
            handleTermClick(entry.ci, entry.ti, pill),
          );
          page.appendChild(pill);
        });
        termsTrack.appendChild(page);
        termsTrack.style.transform = "";
        termsTrack.style.transition = "";
      }

      termsPrev.addEventListener("click", () => {
        if (currentPage > 0) {
          currentPage--;
          scrollToPage();
        }
      });
      termsNext.addEventListener("click", () => {
        if (currentPage < pageBreaks.length - 1) {
          currentPage++;
          scrollToPage();
        }
      });

      // --- Category selection ---
      document
        .querySelectorAll<HTMLElement>(".category-pill")
        .forEach((btn) => {
          btn.addEventListener("click", () => {
            const raw = btn.dataset.category!;
            const key: "all" | number = raw === "all" ? "all" : parseInt(raw);

            if (activeCategory === key) {
              activeCategory = null;
              activeTerm = null;
              btn.classList.remove("active");
              categoryNav.classList.remove("has-selection");
              termsSection.classList.add("hidden");
              detailSection.classList.add("hidden");
              return;
            }

            document
              .querySelectorAll(".category-pill.active")
              .forEach((b) => b.classList.remove("active"));
            activeCategory = key;
            activeTerm = null;
            btn.classList.add("active");
            categoryNav.classList.add("has-selection");
            detailSection.classList.add("hidden");

            currentTerms = getTermsForCategory(data, key, allTerms);
            currentPage = 0;
            termsSection.classList.remove("hidden");
            if (!isMobile()) {
              buildTermsPages();
              renderAllPages();
            } else {
              renderAllTerms();
            }
          });
        });

      // --- Recompute pagination on resize ---
      let resizeTimer: ReturnType<typeof setTimeout>;
      window.addEventListener("resize", () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
          if (!isMobile() && activeCategory !== null) {
            buildCatPages();
            renderCatPage();
            buildTermsPages();
            renderAllPages();
          }
        }, 150);
      });

      // --- Detail card callbacks ---
      function navigateToTerm(entry: TermEntry) {
        activeTerm = termKey(entry.ci, entry.ti);
        const idx = currentTerms.findIndex(
          (e) => e.ci === entry.ci && e.ti === entry.ti,
        );
        if (idx >= 0) {
          currentPage = findPageForIndex(pageBreaks, idx);
          renderAllPages();
        }
        buildDetailCard(
          detailModalCard,
          entry.term,
          data,
          basePath,
          detailCallbacks,
        );
      }

      function handleShuffle() {
        if (activeCategory === null) return;
        const pool = getTermsForCategory(data, activeCategory, allTerms);
        const pick = pickRandomTerm(pool, activeTerm);
        if (!pick) return;
        navigateToTerm(pick);
      }

      function openLightbox(lightSrc: string, darkSrc: string, alt: string) {
        lbImgLight.src = lightSrc;
        lbImgLight.alt = alt;
        lbImgDark.src = darkSrc;
        lbImgDark.alt = alt;
        lightbox.showModal();
      }

      const detailCallbacks = {
        onRelatedTermClick: navigateToTerm,
        onShuffleClick: handleShuffle,
        onDiagramClick: openLightbox,
      };

      // --- Term click handler ---
      function handleTermClick(ci: number, ti: number, pill: HTMLElement) {
        const key = termKey(ci, ti);
        if (activeTerm === key) {
          activeTerm = null;
          pill.classList.remove("active");
          detailSection.classList.add("hidden");
          return;
        }

        document
          .querySelectorAll(".term-pill.active")
          .forEach((b) => b.classList.remove("active"));
        activeTerm = key;
        pill.classList.add("active");

        const term = data[ci].terms[ti];
        buildDetailCard(detailModalCard, term, data, basePath, detailCallbacks);
        detailModal.showModal();
      }

      // --- Modal close ---
      detailModalClose.addEventListener("click", () => detailModal.close());
      detailModal.addEventListener("click", (e) => {
        if (e.target === detailModal) detailModal.close();
      });
      detailModal.addEventListener("close", () => {
        activeTerm = null;
        document
          .querySelectorAll(".term-pill.active")
          .forEach((b) => b.classList.remove("active"));
      });

      // --- Lightbox close ---
      lbClose.addEventListener("click", () => lightbox.close());
      lightbox.addEventListener("click", (e) => {
        if (e.target === lightbox) lightbox.close();
      });

      // --- Init ---
      if (!isMobile()) buildCatPages();
      const showAllBtn = document.querySelector<HTMLElement>(
        '.category-pill[data-category="all"]',
      );
      if (showAllBtn) showAllBtn.click();
    </script>
  </body>
</html>

<style is:global>
  /* Pill styles need is:global because JS creates elements dynamically without Astro scoping */
  .pill {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--fg-muted);
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 0.35rem 0.75rem;
    cursor: pointer;
    white-space: nowrap;
    transition:
      border-color 0.15s ease,
      color 0.15s ease,
      background-color 0.15s ease;
  }
  .pill:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .pill.active {
    color: var(--accent);
    border-color: var(--accent);
    background-color: color-mix(in srgb, var(--accent) 10%, transparent);
  }
  .pill.note-card {
    text-decoration: none;
  }
  .detail-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;
  }
  .detail-card {
    position: relative;
  }
  .detail-shuffle {
    position: absolute;
    top: clamp(0.75rem, 2vw, 1rem);
    right: clamp(0.75rem, 2vw, 1rem);
  }
  .shuffle-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.7rem;
    font-size: 0.78rem;
  }
  .shuffle-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .hidden {
    display: none;
  }

  /* Detail card */
  .detail-card {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: clamp(1rem, 2vw, 1.5rem);
  }
  .detail-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 0.75rem;
    padding-right: 5.5rem;
  }
  .detail-logo-title {
    margin-bottom: 0.75rem;
    padding-right: 5.5rem;
  }
  .detail-logo-title img {
    height: 64px;
    width: auto;
  }
  .detail-logo-title img.logo-dark {
    display: none;
  }
  [data-theme="dark"] .detail-logo-title img.logo-dark,
  :root:not([data-theme="light"]) .detail-logo-title img.logo-dark {
    display: inline;
  }
  [data-theme="dark"] .detail-logo-title img.logo-light,
  :root:not([data-theme="light"]) .detail-logo-title img.logo-light {
    display: none;
  }
  .detail-desc {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    color: var(--fg-muted);
    line-height: 1.65;
    margin-bottom: 1rem;
  }
  .detail-diagram {
    margin-bottom: 1rem;
    text-align: center;
    position: relative;
  }
  .detail-diagram-clickable {
    border-radius: 8px;
    transition:
      opacity 0.15s ease,
      box-shadow 0.15s ease;
  }
  .detail-diagram-clickable:hover {
    opacity: 0.85;
    box-shadow: 0 0 0 2px var(--accent);
  }
  .detail-diagram img {
    max-width: 100%;
    max-height: 400px;
    object-fit: contain;
    border-radius: 8px;
  }
  .detail-diagram img.diagram-dark {
    display: none;
  }
  :root:not([data-theme="light"]) .detail-diagram img.diagram-dark {
    display: inline;
  }
  :root:not([data-theme="light"]) .detail-diagram img.diagram-light {
    display: none;
  }
  .detail-see-more {
    border-top: 1px solid var(--line);
    padding-top: 0.75rem;
  }
  .detail-related {
    border-top: 1px solid var(--line);
    padding-top: 0.75rem;
    margin-top: 0.75rem;
  }
  .detail-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--fg-soft);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
    text-align: center;
  }

  /* Lightbox */
  .lightbox {
    border: none;
    background: var(--bg-card);
    max-width: 90vw;
    max-height: 90vh;
    padding: 1.5rem;
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3);
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    margin: 0;
  }
  .lightbox::backdrop {
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
