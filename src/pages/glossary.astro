---
import "../styles/global.css";
import { BASE } from "../lib/base";
import { getCollection } from "astro:content";
import Logo from "../components/Logo.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import SearchBar from "../components/SearchBar.astro";
import glossaryData from "../data/glossary.json";

const notes = await getCollection("notes");
const noteMap = new Map(notes.map((n) => [n.id, n.data.title]));

// Validate all slugs at build time
for (const category of glossaryData) {
  for (const term of category.terms) {
    for (const ref of term.notes) {
      if (!noteMap.has(ref.slug)) {
        throw new Error(`Glossary: invalid slug "${ref.slug}" for term "${term.term}"`);
      }
    }
  }
}

// Sort terms alphabetically within each category
for (const category of glossaryData) {
  category.terms.sort((a, b) => a.term.localeCompare(b.term));
}

// Build resolved data for client-side use (resolve slugs to titles at build time)
const resolvedData = glossaryData.map((cat) => ({
  ...cat,
  terms: cat.terms.map((term) => ({
    ...term,
    notes: term.notes.map((ref) => ({
      ...ref,
      title: noteMap.get(ref.slug) as string,
      href: `${BASE}/notes/${ref.slug}/${ref.anchor ?? ""}`,
    })),
  })),
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Glossary of Terms — Data Engineering Specialization</title>
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    <script is:inline>
      (function() {
        var saved = localStorage.getItem("theme");
        if (saved === "light") {
          document.documentElement.setAttribute("data-theme", "light");
        } else if (!saved && window.matchMedia("(prefers-color-scheme: light)").matches) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
  </head>
  <body>
    <div class="glossary-page">
      <header class="home-topbar">
        <Logo />
        <div class="home-topbar-actions">
          <SearchBar />
          <ThemeToggle />
        </div>
      </header>

      <section class="glossary-hero">
        <h1 class="glossary-title">Glossary of Terms</h1>
        <p class="glossary-subtitle">
          Key concepts and technologies covered across all four courses.
        </p>
      </section>

      <div class="glossary-layout">
        <nav class="category-nav" aria-label="Browse by category">
          {glossaryData.map((cat, i) => (
            <button class="pill category-pill" data-category={i}>
              {cat.icon} {cat.category}
            </button>
          ))}
          <button class="pill category-pill" data-category="all">📋 Show All</button>
        </nav>

        <section id="terms-section" class="terms-section hidden">
          <div id="terms-pills" class="terms-pills"></div>
        </section>

        <section id="detail-section" class="detail-section hidden">
          <div id="detail-card" class="detail-card"></div>
        </section>
      </div>

      <dialog id="lightbox" class="lightbox">
        <button class="lightbox-close" aria-label="Close">&times;</button>
        <img id="lightbox-img-light" class="lightbox-img diagram-light" alt="" />
        <img id="lightbox-img-dark" class="lightbox-img diagram-dark" alt="" />
      </dialog>

      <!-- Hidden data for Pagefind indexing -->
      <div class="sr-only" data-pagefind-body>
        {resolvedData.map((cat) => (
          <div>
            <h2>{cat.icon} {cat.category}</h2>
            {cat.terms.map((term) => (
              <p data-pagefind-weight="2">{term.term}</p>
            ))}
          </div>
        ))}
      </div>

      <footer class="glossary-footer">
        <p>Built with Astro. Notes from the DeepLearning.AI Data Engineering Specialization on Coursera.</p>
      </footer>
    </div>

    <script define:vars={{ resolvedData, BASE }}>
      const data = resolvedData;
      const basePath = BASE;
      const termsPills = document.getElementById("terms-pills");
      const termsSection = document.getElementById("terms-section");
      const detailCard = document.getElementById("detail-card");
      const detailSection = document.getElementById("detail-section");

      let activeCategory = null;
      let activeTerm = null;

      function clearChildren(el) {
        while (el.firstChild) el.removeChild(el.firstChild);
      }

      const allTerms = [];
      data.forEach((cat, ci) => {
        cat.terms.forEach((term, ti) => {
          allTerms.push({ term, ci, ti });
        });
      });
      allTerms.sort((a, b) => a.term.term.localeCompare(b.term.term));

      document.querySelectorAll(".category-pill").forEach((btn) => {
        btn.addEventListener("click", () => {
          const raw = btn.dataset.category;
          const key = raw === "all" ? "all" : parseInt(raw);

          if (activeCategory === key) {
            activeCategory = null;
            activeTerm = null;
            btn.classList.remove("active");
            termsSection.classList.add("hidden");
            detailSection.classList.add("hidden");
            return;
          }

          document.querySelectorAll(".category-pill.active").forEach((b) => b.classList.remove("active"));
          activeCategory = key;
          activeTerm = null;
          btn.classList.add("active");
          detailSection.classList.add("hidden");

          clearChildren(termsPills);
          const terms = key === "all" ? allTerms : data[key].terms.map((term, ti) => ({ term, ci: key, ti }));
          terms.forEach((entry) => {
            const pill = document.createElement("button");
            pill.className = "pill term-pill";
            pill.textContent = entry.term.term;
            pill.addEventListener("click", () => handleTermClick(entry.ci, entry.ti, pill));
            termsPills.appendChild(pill);
          });
          termsSection.classList.remove("hidden");
        });
      });

      function handleTermClick(ci, ti, pill) {
        const key = ci + "-" + ti;
        if (activeTerm === key) {
          activeTerm = null;
          pill.classList.remove("active");
          detailSection.classList.add("hidden");
          return;
        }

        document.querySelectorAll(".term-pill.active").forEach((b) => b.classList.remove("active"));
        activeTerm = key;
        pill.classList.add("active");

        clearChildren(detailCard);
        const term = data[ci].terms[ti];

        // Term name
        const title = document.createElement("h3");
        title.className = "detail-title";
        title.textContent = term.term;
        detailCard.appendChild(title);

        // Description
        if (term.description) {
          const desc = document.createElement("p");
          desc.className = "detail-desc";
          desc.textContent = term.description;
          detailCard.appendChild(desc);
        }

        // Diagram
        if (term.diagram) {
          const isPng = term.diagram.endsWith(".png");
          const baseName = isPng ? term.diagram.replace(".png", "") : term.diagram;
          const ext = isPng ? "png" : "svg";

          const lightSrc = basePath + "/images/diagrams/" + baseName + "." + ext;
          const darkSrc = basePath + "/images/diagrams/" + baseName + "-dark." + ext;

          const diagramWrap = document.createElement("div");
          diagramWrap.className = "detail-diagram";

          const expandBtn = document.createElement("button");
          expandBtn.className = "diagram-expand";
          expandBtn.setAttribute("aria-label", "Enlarge diagram");
          expandBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg>';
          expandBtn.addEventListener("click", () => openLightbox(lightSrc, darkSrc, term.term));
          diagramWrap.appendChild(expandBtn);

          const imgLight = document.createElement("img");
          imgLight.src = lightSrc;
          imgLight.alt = term.term;
          imgLight.className = "diagram diagram-light";
          diagramWrap.appendChild(imgLight);

          const imgDark = document.createElement("img");
          imgDark.src = darkSrc;
          imgDark.alt = term.term;
          imgDark.className = "diagram diagram-dark";
          diagramWrap.appendChild(imgDark);

          detailCard.appendChild(diagramWrap);
        }

        // See more at
        const seeMore = document.createElement("div");
        seeMore.className = "detail-see-more";

        const label = document.createElement("span");
        label.className = "detail-label";
        label.textContent = "See more at:";
        seeMore.appendChild(label);

        const links = document.createElement("div");
        links.className = "detail-links";
        term.notes.forEach((ref) => {
          const a = document.createElement("a");
          a.href = ref.href;
          a.className = "pill note-card";
          a.textContent = ref.title;
          links.appendChild(a);
        });
        seeMore.appendChild(links);
        detailCard.appendChild(seeMore);

        detailSection.classList.remove("hidden");
      }

      // Lightbox
      const lightbox = document.getElementById("lightbox");
      const lbImgLight = document.getElementById("lightbox-img-light");
      const lbImgDark = document.getElementById("lightbox-img-dark");
      const lbClose = lightbox.querySelector(".lightbox-close");

      function openLightbox(lightSrc, darkSrc, alt) {
        lbImgLight.src = lightSrc;
        lbImgLight.alt = alt;
        lbImgDark.src = darkSrc;
        lbImgDark.alt = alt;
        lightbox.showModal();
      }

      lbClose.addEventListener("click", () => lightbox.close());
      lightbox.addEventListener("click", (e) => {
        if (e.target === lightbox) lightbox.close();
      });
    </script>
  </body>
</html>

<style is:global>
/* Pill styles need is:global because JS creates elements dynamically without Astro scoping */
.pill { font-family: var(--font-sans); font-size: 0.78rem; font-weight: 500; color: var(--fg-muted); background: var(--bg-card); border: 1px solid var(--line); border-radius: 20px; padding: 0.35rem 0.75rem; cursor: pointer; white-space: nowrap; transition: border-color 0.15s ease, color 0.15s ease, background-color 0.15s ease; }
.pill:hover { color: var(--accent); border-color: var(--accent); }
.pill.active { color: var(--accent); border-color: var(--accent); background-color: color-mix(in srgb, var(--accent) 10%, transparent); }
.pill.note-card { text-decoration: none; }
.terms-pills, .detail-links { display: flex; flex-wrap: wrap; gap: 0.4rem; justify-content: center; }
.hidden { display: none; }

/* Detail card */
.detail-card { background: var(--bg-card); border: 1px solid var(--line); border-radius: 14px; padding: clamp(1rem, 2vw, 1.5rem); }
.detail-title { font-family: var(--font-serif); font-size: 1.15rem; font-weight: 600; color: var(--fg); margin-bottom: 0.75rem; }
.detail-desc { font-family: var(--font-sans); font-size: 0.88rem; color: var(--fg-muted); line-height: 1.65; margin-bottom: 1rem; }
.detail-diagram { margin-bottom: 1rem; text-align: center; position: relative; }
.diagram-expand { position: absolute; top: 0.4rem; right: 0.4rem; background: var(--bg-card); border: 1px solid var(--line); color: var(--fg-soft); width: 1.75rem; height: 1.75rem; border-radius: 6px; cursor: pointer; display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.15s ease, color 0.15s ease, border-color 0.15s ease; }
.detail-diagram:hover .diagram-expand { opacity: 1; }
.diagram-expand:hover { color: var(--accent); border-color: var(--accent); }
.detail-diagram img { max-width: 100%; max-height: 400px; object-fit: contain; border-radius: 8px; }
.detail-diagram img.diagram-dark { display: none; }
:root:not([data-theme="light"]) .detail-diagram img.diagram-dark { display: inline; }
:root:not([data-theme="light"]) .detail-diagram img.diagram-light { display: none; }
.detail-see-more { border-top: 1px solid var(--line); padding-top: 0.75rem; }
.detail-label { display: block; font-family: var(--font-sans); font-size: 0.75rem; font-weight: 600; color: var(--fg-soft); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; text-align: center; }

/* Lightbox */
.lightbox { border: none; background: var(--bg-card); max-width: 90vw; max-height: 90vh; padding: 1.5rem; border-radius: 16px; box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3); position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); margin: 0; }
.lightbox::backdrop { background: rgba(0, 0, 0, 0.4); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
.lightbox .lightbox-img { max-width: 85vw; max-height: 80vh; object-fit: contain; border-radius: 10px; display: block; }
.lightbox .lightbox-close { position: absolute; top: 0.5rem; right: 0.5rem; background: none; color: var(--fg-soft); border: none; font-size: 1.5rem; width: 2rem; height: 2rem; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: color 0.15s ease, background 0.15s ease; }
.lightbox .lightbox-close:hover { color: var(--fg); background: var(--bg-hover); }
.lightbox .diagram-dark { display: none; }
:root:not([data-theme="light"]) .lightbox .diagram-dark { display: inline; }
:root:not([data-theme="light"]) .lightbox .diagram-light { display: none; }
</style>

<style>
.glossary-page { max-width: 1200px; margin: 0 auto; padding: clamp(1.5rem, 3vw, 2.5rem); min-height: 100vh; display: flex; flex-direction: column; }
.home-topbar { display: flex; align-items: center; justify-content: space-between; padding-bottom: 2rem; border-bottom: 1px solid var(--line); margin-bottom: 2rem; }
.home-topbar-actions { display: flex; align-items: center; gap: 0.5rem; }

.glossary-hero { text-align: center; margin-bottom: 1.5rem; }
.glossary-title { font-family: var(--font-serif); font-size: clamp(1.8rem, 4vw, 2.5rem); font-weight: 700; color: var(--fg); margin-bottom: 0.5rem; line-height: 1.2; }
.glossary-subtitle { font-family: var(--font-sans); font-size: clamp(0.9rem, 2vw, 1rem); color: var(--fg-muted); line-height: 1.6; }

/* Three-column horizontal layout */
.glossary-layout { display: flex; gap: 1rem; margin-bottom: 2rem; align-items: flex-start; }
.category-nav { display: flex; flex-wrap: wrap; gap: 0.4rem; flex-shrink: 0; width: 33%; position: sticky; top: 1rem; align-content: flex-start; }
.terms-section { flex: 1; min-width: 0; }
.detail-section { flex: 1; min-width: 0; position: sticky; top: 1rem; }

@media (max-width: 768px) {
  .glossary-layout { flex-direction: column; }
  .category-nav { flex-direction: row; flex-wrap: wrap; width: auto; position: static; justify-content: center; }
  .detail-section { position: static; }
}

.sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }

.glossary-footer { margin-top: auto; padding-top: 2rem; border-top: 1px solid var(--line); text-align: center; }
.glossary-footer p { font-size: 0.78rem; color: var(--fg-soft); font-family: var(--font-sans); }

@media (max-width: 640px) {
  .home-topbar-actions .search-wrapper { max-width: 160px; }
}
</style>
